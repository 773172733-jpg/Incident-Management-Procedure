/* 事件树 - 通用样式 */

/* 页面容器 */
.page {
  min-height: 100vh;
  background-color: #F7F8FA;
  box-sizing: border-box;
  padding-bottom: calc(112px + env(safe-area-inset-bottom));
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  padding: 16px;
  margin: 0 16px 12px;
}

/* 按钮 - 主色 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 500;
  border-radius: 14px;
  border: none;
  cursor: pointer;
}
.btn-primary:active {
  opacity: 0.85;
}
.btn-primary[disabled] {
  opacity: 0.5;
}

/* 按钮 - 次要 */
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 44px;
  background: #FFFFFF;
  color: #1F2329;
  font-size: 14px;
  border-radius: 14px;
  border: 1px solid #EEF0F3;
}
.btn-secondary:active {
  background: #F5F5F5;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  font-size: 11px;
  border-radius: 999px;
  white-space: nowrap;
}

/* 优先级标签 */
.tag-core {
  background: #FFF1F0;
  color: #F04A4A;
}
.tag-important {
  background: #FFFBE6;
  color: #F6B90A;
}
.tag-optional {
  background: #F5F5F5;
  color: #8A9099;
}

/* 分割线 */
.divider {
  height: 1px;
  background: #EEF0F3;
  margin: 12px 0;
}

/* 页面标题区域 */
.page-header {
  padding: 28px 16px 16px;
}
.page-header__title {
  font-size: 24px;
  font-weight: 600;
  color: #1F2329;
}
.page-header__subtitle {
  font-size: 12px;
  color: #8A9099;
  margin-top: 4px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
}
.empty-state__text {
  font-size: 14px;
  color: #8A9099;
  text-align: center;
  line-height: 1.6;
}
.empty-state__btn {
  margin-top: 20px;
  width: 180px;
}

button::after { border: none; }

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 22px 16px 12px;
  color: #1F2329;
  font-size: 17px;
  font-weight: 600;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}
