/* 事件树 - 通用样式 */

/* 页面容器 */
.page {
  min-height: 100vh;
  background-color: var(--page-bg, #F7F8FA);
  padding-bottom: 20px;
}

/* 卡片 */
.card {
  background: var(--card-bg, #FFFFFF);
  border-radius: var(--radius-card, 16px);
  box-shadow: var(--shadow-card, 0 2px 8px rgba(0, 0, 0, 0.04));
  padding: var(--spacing-lg, 16px);
  margin: 0 var(--spacing-lg, 16px) var(--spacing-md, 12px);
}

/* 按钮 - 主色 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  background: var(--primary, #FF6B35);
  color: #FFFFFF;
  font-size: var(--font-lg, 16px);
  font-weight: var(--weight-medium, 500);
  border-radius: var(--radius-btn, 14px);
  border: none;
  cursor: pointer;
}
.btn-primary:active {
  opacity: 0.85;
}
.btn-primary[disabled] {
  opacity: 0.5;
}

/* 按钮 - 次要 */
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 44px;
  background: var(--card-bg, #FFFFFF);
  color: var(--text-primary, #1F2329);
  font-size: var(--font-md, 14px);
  border-radius: var(--radius-btn, 14px);
  border: 1px solid var(--divider, #EEF0F3);
}
.btn-secondary:active {
  background: #F5F5F5;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  font-size: var(--font-xs, 11px);
  border-radius: var(--radius-tag, 999px);
  white-space: nowrap;
}

/* 优先级标签 */
.tag-core {
  background: #FFF1F0;
  color: #F04A4A;
}
.tag-important {
  background: #FFFBE6;
  color: #F6B90A;
}
.tag-optional {
  background: #F5F5F5;
  color: #8A9099;
}

/* 分割线 */
.divider {
  height: 1px;
  background: var(--divider, #EEF0F3);
  margin: var(--spacing-md, 12px) 0;
}

/* 页面标题区域 */
.page-header {
  padding: var(--spacing-xl, 20px) var(--spacing-lg, 16px) var(--spacing-md, 12px);
}
.page-header__title {
  font-size: var(--font-xxl, 24px);
  font-weight: var(--weight-bold, 600);
  color: var(--text-primary, #1F2329);
}
.page-header__subtitle {
  font-size: var(--font-sm, 12px);
  color: var(--text-secondary, #8A9099);
  margin-top: 4px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
}
.empty-state__text {
  font-size: var(--font-md, 14px);
  color: var(--text-secondary, #8A9099);
  text-align: center;
  line-height: 1.6;
}
.empty-state__btn {
  margin-top: 20px;
  width: 180px;
}
