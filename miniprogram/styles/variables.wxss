/* 事件树 - 样式变量 */
page {
  /* 颜色变量 */
  --primary: #FF6B35;
  --primary-light: #FFF1EA;
  --page-bg: #F7F8FA;
  --card-bg: #FFFFFF;
  --text-primary: #1F2329;
  --text-secondary: #8A9099;
  --text-disabled: #B8BEC7;
  --divider: #EEF0F3;
  --success: #22B573;
  --warning: #F6B90A;
  --danger: #F04A4A;
  --info: #4E8DF5;

  /* 圆角 */
  --radius-card: 16px;
  --radius-btn: 14px;
  --radius-tag: 999px;
  --radius-sm: 8px;
  --radius-xs: 4px;

  /* 阴影 */
  --shadow-card: 0 8px 24px rgba(31, 35, 41, 0.05);
  --shadow-elevated: 0 10px 28px rgba(31, 35, 41, 0.08);

  /* 间距 */
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 20px;
  --spacing-xxl: 24px;
  --spacing-huge: 32px;

  /* 字号 */
  --font-xs: 11px;
  --font-sm: 12px;
  --font-md: 14px;
  --font-lg: 16px;
  --font-xl: 18px;
  --font-xxl: 24px;

  /* 字重 */
  --weight-normal: 400;
  --weight-medium: 500;
  --weight-bold: 600;
}
