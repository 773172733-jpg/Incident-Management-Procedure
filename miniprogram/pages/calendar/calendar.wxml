<view class="page tab-page"><view class="page-header"><view class="page-header__title">日历</view><view class="page-header__subtitle">按日期查看有时间安排的任务</view></view><view class="preview-card"><view class="preview-top"><text class="preview-month">本月</text><view class="calendar-icon"><view class="calendar-line"></view></view></view><view class="week-row"><text wx:for="{{['一','二','三','四','五','六','日']}}" wx:key="*this">{{item}}</text></view><view class="calendar-placeholder"><view wx:for="{{[1,2,3,4,5]}}" wx:key="*this" class="calendar-row"><view wx:for="{{[1,2,3,4,5,6,7]}}" wx:key="*this" class="day-dot"></view></view></view></view><empty-state title="日历功能尚未开放" description="阶段2.5只完成视觉封板，不提前开发提醒与完整日历功能"></empty-state></view>
