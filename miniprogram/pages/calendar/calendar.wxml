<view class="page calendar-page"><view class="page-header"><view class="page-header__title">日历</view><view class="page-header__subtitle">按日期查看有时间安排的任务</view></view><loading-skeleton wx:if="{{loading}}" rows="4"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="日历加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><block wx:else><view class="calendar-card"><view class="month-nav"><button class="month-button" bindtap="previousMonth"><view class="arrow arrow--left"></view></button><text class="month-title">{{monthTitle}}</text><button class="today-button" bindtap="today">今天</button><button class="month-button" bindtap="nextMonth"><view class="arrow arrow--right"></view></button></view><view wx:if="{{monthChanging}}" class="month-loading">正在切换月份</view><view class="week-row"><text wx:for="{{['一','二','三','四','五','六','日']}}" wx:key="*this" class="{{index>4?'weekend':''}}">{{item}}</text></view><view class="days"><view wx:for="{{days}}" wx:key="key" class="day {{item.inMonth?'':'day--muted'}} {{item.isToday?'day--today':''}} {{item.selected?'day--selected':''}}" data-key="{{item.key}}" bindtap="selectDay"><text>{{item.day}}</text><view wx:if="{{item.marker}}" class="marker marker--{{item.marker}}"></view></view></view></view><view class="date-summary"><view><text class="date-title">{{selectedLabel}}</text><text class="date-count">{{summary.total}}项任务</text></view><view class="summary-values"><text>{{summary.pending}}未完成</text><text>{{summary.completed}}已完成</text><text wx:if="{{summary.overdue}}" class="overdue">{{summary.overdue}}逾期</text></view></view><empty-state wx:if="{{!monthTaskCount}}" title="本月还没有安排" description="设置任务时间后，会显示在日历中"></empty-state><empty-state wx:elif="{{!selectedTasks.length}}" title="当天没有任务" description="选择有圆点标记的日期查看任务"></empty-state><view wx:else class="day-tasks"><schedule-task-card wx:for="{{selectedTasks}}" wx:key="_id" item="{{item}}" operating="{{operatingId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card></view></block></view>
