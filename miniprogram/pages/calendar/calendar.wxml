<view class="page calendar-page">
  <view class="page-header"><view class="page-header__title">日历</view><view class="page-header__subtitle">按日期查看大事件和分支任务</view></view>
  <loading-skeleton wx:if="{{loading && !hasLoaded}}" rows="4"></loading-skeleton>
  <empty-state wx:elif="{{error && !monthEntryCount}}" type="error" title="日历加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state>
  <block wx:else>
    <view class="calendar-card"><view class="month-nav"><button class="month-button" bindtap="previousMonth"><view class="arrow arrow--left"></view></button><text class="month-title">{{monthTitle}}</text><button class="today-button" bindtap="today">今天</button><button class="month-button" bindtap="nextMonth"><view class="arrow arrow--right"></view></button></view><view wx:if="{{monthChanging}}" class="month-loading">正在切换月份</view><view class="week-row"><text wx:for="{{['一','二','三','四','五','六','日']}}" wx:key="*this" class="{{index>4?'weekend':''}}">{{item}}</text></view><view class="days"><view wx:for="{{days}}" wx:key="key" class="day {{item.inMonth?'':'day--muted'}} {{item.isToday?'day--today':''}} {{item.selected?'day--selected':''}}" data-key="{{item.key}}" bindtap="selectDay"><text>{{item.day}}</text><view wx:if="{{item.marker}}" class="marker marker--{{item.marker}}"></view></view></view></view>
    <view wx:if="{{error}}" class="inline-error" bindtap="retry">{{error}}，点击重试</view>
    <view class="date-summary"><view><text class="date-title">{{selectedLabel}}</text><text class="date-count">{{summary.total}}项安排</text></view><view class="summary-values"><text>{{summary.projectCount}}个大事件</text><text>{{summary.taskCount}}个分支任务</text></view></view>
    <empty-state wx:if="{{!monthEntryCount}}" title="本月还没有安排" description="为大事件或分支任务设置时间后，会显示在日历中"></empty-state>
    <empty-state wx:elif="{{!selectedEntries.length}}" title="当天没有时间安排" description="没有设置时间的大事件和分支任务不会出现在日历中"></empty-state>
    <view wx:else class="day-entries">
      <block wx:if="{{selectedProjects.length}}"><view class="entry-heading">大事件</view><view wx:for="{{selectedProjects}}" wx:key="id" class="project-entry {{item.isArchived?'project-entry--archived':''}} {{item.isCompleted?'project-entry--completed':''}}" data-item="{{item}}" bindtap="openEntry"><view class="project-entry__icon" style="color:{{item.themeColor}};background:{{item.themeColor}}1A">{{item.iconValue}}</view><view class="project-entry__main"><view class="project-entry__title-row"><text class="project-entry__title">{{item.title}}</text><text class="entry-status entry-status--{{item.status}}">{{item.statusText}}</text></view><text class="project-entry__time">{{item.timeText}}</text></view><view class="entry-chevron"></view></view></block>
      <block wx:if="{{selectedTasks.length}}"><view class="entry-heading">分支任务</view><schedule-task-card wx:for="{{selectedTasks}}" wx:key="id" item="{{item}}" operating="{{operatingId===item.id}}" bind:open="openEntry" bind:toggle="toggleTask"></schedule-task-card></block>
    </view>
  </block>
</view>
