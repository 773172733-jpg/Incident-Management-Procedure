@import '../../styles/variables.wxss';
@import '../../styles/common.wxss';
.calendar-page{padding-top:env(safe-area-inset-top)}.calendar-card{position:relative;margin:0 32rpx 24rpx;padding:28rpx;border-radius:30rpx;background:#fff;box-shadow:var(--shadow-card)}.month-nav{display:flex;align-items:center}.month-title{flex:1;text-align:center;color:#1F2329;font-size:31rpx;font-weight:600;white-space:nowrap}.month-button{display:flex;align-items:center;justify-content:center;width:58rpx;height:58rpx;margin:0;padding:0;border-radius:18rpx;background:#F7F8FA}.arrow{width:15rpx;height:15rpx;border-top:3rpx solid #59606A;border-right:3rpx solid #59606A}.arrow--left{transform:rotate(-135deg)}.arrow--right{transform:rotate(45deg)}.today-button{height:52rpx;margin:0 12rpx 0 0;padding:0 17rpx;border-radius:16rpx;background:#FFF1EA;color:#FF6B35;font-size:21rpx;line-height:52rpx}.month-loading{position:absolute;left:0;right:0;top:92rpx;text-align:center;color:#FF6B35;font-size:18rpx}.week-row,.days{display:grid;grid-template-columns:repeat(7,1fr)}.week-row{margin-top:30rpx}.week-row text{text-align:center;color:#8A9099;font-size:20rpx}.week-row .weekend{color:#A7ADB5}.days{margin-top:14rpx;row-gap:9rpx}.day{position:relative;display:flex;align-items:center;justify-content:center;height:70rpx;color:#1F2329;font-size:24rpx}.day text{display:flex;align-items:center;justify-content:center;width:52rpx;height:52rpx;border-radius:50%}.day--muted{opacity:.34}.day--today text{box-sizing:border-box;border:2rpx solid #FFB18E;background:#FFF8F4}.day--selected text{border-color:#FF6B35;background:#FF6B35;color:#fff}.marker{position:absolute;left:50%;bottom:2rpx;width:8rpx;height:8rpx;border-radius:50%;transform:translateX(-50%)}.marker--active{background:#FF6B35}.marker--completed{background:#22B573}.marker--muted{background:#A7ADB5}.date-summary{display:flex;align-items:center;justify-content:space-between;margin:0 32rpx 22rpx;padding:22rpx 26rpx;border-radius:24rpx;background:#fff}.date-title,.date-count{display:block}.date-title{color:#1F2329;font-size:27rpx;font-weight:600}.date-count{margin-top:6rpx;color:#8A9099;font-size:20rpx}.summary-values{display:flex;flex-direction:column;align-items:flex-end;color:#8A9099;font-size:19rpx}.summary-values text{margin-top:3rpx}.day-entries{padding-bottom:24rpx}.entry-heading{margin:26rpx 32rpx 14rpx;color:#59606A;font-size:24rpx;font-weight:600}.project-entry{display:flex;align-items:center;margin:0 32rpx 18rpx;padding:24rpx 26rpx;border-radius:28rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(31,35,41,.05)}.project-entry--archived{opacity:.58}.project-entry--completed{opacity:.72}.project-entry__icon{display:flex;align-items:center;justify-content:center;width:72rpx;height:72rpx;border-radius:20rpx;font-size:30rpx;font-weight:600;flex-shrink:0}.project-entry__main{flex:1;min-width:0;margin-left:18rpx}.project-entry__title-row{display:flex;align-items:center}.project-entry__title{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1F2329;font-size:27rpx;font-weight:600}.project-entry__time{display:block;margin-top:9rpx;color:#8A9099;font-size:20rpx}.entry-status{margin-left:10rpx;padding:4rpx 10rpx;border-radius:999rpx;background:#FFF1EA;color:#FF6B35;font-size:19rpx;flex-shrink:0}.entry-status--completed{background:#EBF8F1;color:#22B573}.entry-status--archived{background:#F1F2F4;color:#8A9099}.entry-chevron{width:13rpx;height:13rpx;margin-left:14rpx;border-top:3rpx solid #B8BEC7;border-right:3rpx solid #B8BEC7;transform:rotate(45deg)}.inline-error{margin:0 32rpx 18rpx;color:#F04A4A;font-size:21rpx;text-align:center}
