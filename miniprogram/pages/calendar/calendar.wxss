@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.calendar-page{padding-top:env(safe-area-inset-top)}.calendar-card{position:relative;margin:0 32rpx 24rpx;padding:28rpx;border-radius:30rpx;background:#fff;box-shadow:var(--shadow-card)}.month-nav{display:flex;align-items:center}.month-title{flex:1;text-align:center;color:#1F2329;font-size:31rpx;font-weight:600;white-space:nowrap}.month-button{display:flex;align-items:center;justify-content:center;width:58rpx;height:58rpx;margin:0;padding:0;border-radius:18rpx;background:#F7F8FA}.arrow{width:15rpx;height:15rpx;border-top:3rpx solid #59606A;border-right:3rpx solid #59606A}.arrow--left{transform:rotate(-135deg)}.arrow--right{transform:rotate(45deg)}.today-button{height:52rpx;margin:0 12rpx 0 0;padding:0 17rpx;border-radius:16rpx;background:#FFF1EA;color:#FF6B35;font-size:21rpx;line-height:52rpx}.month-loading{position:absolute;left:0;right:0;top:92rpx;text-align:center;color:#FF6B35;font-size:18rpx}.week-row,.days{display:grid;grid-template-columns:repeat(7,1fr)}.week-row{margin-top:30rpx}.week-row text{text-align:center;color:#8A9099;font-size:20rpx}.week-row .weekend{color:#A7ADB5}.days{margin-top:14rpx;row-gap:9rpx}.day{position:relative;display:flex;align-items:center;justify-content:center;height:70rpx;color:#1F2329;font-size:24rpx}.day text{display:flex;align-items:center;justify-content:center;width:52rpx;height:52rpx;border-radius:50%}.day--muted{opacity:.34}.day--today text{box-sizing:border-box;border:2rpx solid #FFB18E;background:#FFF8F4}.day--selected text{border-color:#FF6B35;background:#FF6B35;color:#fff}.marker{position:absolute;left:50%;bottom:2rpx;width:8rpx;height:8rpx;border-radius:50%;transform:translateX(-50%)}.marker--pending{background:#FF6B35}.marker--completed{background:#22B573}.marker--overdue{background:#F04A4A}.date-summary{display:flex;align-items:center;justify-content:space-between;margin:0 32rpx 22rpx;padding:22rpx 26rpx;border-radius:24rpx;background:#fff}.date-title,.date-count{display:block}.date-title{color:#1F2329;font-size:27rpx;font-weight:600}.date-count{margin-top:6rpx;color:#8A9099;font-size:20rpx}.summary-values{display:flex;flex-direction:column;align-items:flex-end;color:#8A9099;font-size:19rpx}.summary-values text{margin-top:3rpx}.summary-values .overdue{color:#F04A4A}.day-tasks{padding-bottom:24rpx}
