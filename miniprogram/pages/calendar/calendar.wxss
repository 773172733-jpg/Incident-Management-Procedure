@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.tab-page{padding-top:env(safe-area-inset-top)}.preview-card{margin:0 32rpx;padding:28rpx;border-radius:30rpx;background:#fff;box-shadow:var(--shadow-card)}.preview-top{display:flex;justify-content:space-between}.preview-month{font-size:30rpx;font-weight:600;color:#1F2329}.calendar-icon{position:relative;width:38rpx;height:38rpx;border:3rpx solid #FF6B35;border-radius:8rpx}.calendar-line{position:absolute;left:4rpx;right:4rpx;top:10rpx;border-top:3rpx solid #FF6B35}.week-row,.calendar-row{display:flex;justify-content:space-between;margin-top:24rpx}.week-row text{width:50rpx;text-align:center;color:#8A9099;font-size:21rpx}.day-dot{width:50rpx;height:22rpx;border-radius:8rpx;background:#F1F2F4}.calendar-row:nth-child(3) .day-dot:nth-child(4){background:#FFF1EA}
