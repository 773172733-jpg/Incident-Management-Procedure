@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.activity-page{padding-top:env(safe-area-inset-top)}.activity-tabs{display:flex;margin:0 32rpx 18rpx;padding:8rpx;border-radius:22rpx;background:#EEF0F3}.activity-tab{flex:1;height:64rpx;border-radius:17rpx;color:#8A9099;text-align:center;font-size:25rpx;line-height:64rpx}.activity-tab.selected{background:#fff;color:#FF6B35;font-weight:600;box-shadow:0 4rpx 12rpx rgba(31,35,41,.05)}.timeline-preview{position:relative;margin:32rpx 50rpx 0;padding:18rpx 0;opacity:.55}.timeline-line{position:absolute;left:13rpx;top:20rpx;bottom:20rpx;width:3rpx;background:#DDE1E6}.timeline-row{position:relative;display:flex;margin-bottom:24rpx}.timeline-dot{z-index:1;width:28rpx;height:28rpx;border:6rpx solid #FFF1EA;border-radius:50%;background:#FF6B35;box-sizing:border-box}.timeline-skeleton{flex:1;margin-left:20rpx}.timeline-skeleton view{height:18rpx;margin-bottom:11rpx;border-radius:7rpx;background:#E7E9EC}.timeline-skeleton view:last-child{width:62%}
