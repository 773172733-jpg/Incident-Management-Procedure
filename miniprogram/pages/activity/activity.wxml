<view class="page activity-page"><view class="page-header"><view class="page-header__title">动态</view><view class="page-header__subtitle">集中查看待处理事项和操作记录</view></view><view class="activity-tabs"><view class="activity-tab {{tab==='pending'?'selected':''}}" data-tab="pending" bindtap="choose">待处理</view><view class="activity-tab {{tab==='logs'?'selected':''}}" data-tab="logs" bindtap="choose">操作记录</view></view><loading-skeleton wx:if="{{loading}}" rows="4"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="动态加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><block wx:elif="{{tab==='pending'}}"><empty-state wx:if="{{!todayTasks.length&&!upcomingTasks.length&&!overdueTasks.length}}" title="目前没有待处理事项" description="保持这个节奏"></empty-state><block wx:else><section-title wx:if="{{overdueTasks.length}}" title="已逾期"></section-title><schedule-task-card wx:for="{{overdueTasks}}" wx:key="_id" item="{{item}}" operating="{{operatingId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card><section-title wx:if="{{todayTasks.length}}" title="今天到期"></section-title><schedule-task-card wx:for="{{todayTasks}}" wx:key="_id" item="{{item}}" operating="{{operatingId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card><section-title wx:if="{{upcomingTasks.length}}" title="未来3天"></section-title><schedule-task-card wx:for="{{upcomingTasks}}" wx:key="_id" item="{{item}}" operating="{{operatingId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card></block></block><view wx:else class="logs-unavailable"><view class="timeline-preview"><view class="timeline-line"></view><view wx:for="{{[1,2,3]}}" wx:key="*this" class="timeline-row"><view class="timeline-dot"></view><view class="timeline-skeleton"><view></view><view></view></view></view></view><empty-state title="操作记录暂不可用" description="操作记录服务尚未开放；已有记录不会用模拟内容代替展示"></empty-state></view></view>
