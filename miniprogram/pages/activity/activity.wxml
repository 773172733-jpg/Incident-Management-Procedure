<view class="page activity-page">
  <view class="page-header">
    <view class="page-header__title">动态</view>
    <view class="page-header__subtitle">集中查看待处理事项和操作记录</view>
  </view>
  <view class="activity-tabs">
    <view class="activity-tab {{tab==='pending'?'selected':''}}" data-tab="pending" bindtap="chooseTab">待处理</view>
    <view class="activity-tab {{tab==='logs'?'selected':''}}" data-tab="logs" bindtap="chooseTab">操作记录</view>
  </view>

  <scroll-view class="pending-scroll" wx:if="{{tab==='pending'}}" scroll-y enhanced show-scrollbar="{{false}}" refresher-enabled refresher-triggered="{{refreshing}}" bindrefresherrefresh="onPullDownRefresh">
    <loading-skeleton wx:if="{{loading&&!hasLoaded}}" rows="4"></loading-skeleton>
    <empty-state wx:elif="{{error}}" type="error" title="待处理加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state>
    <block wx:else>
      <view class="pending-summary">
        <view class="summary-item summary-item--overdue"><text class="summary-value">{{summary.overdue}}</text><text class="summary-label">已逾期</text></view>
        <view class="summary-item summary-item--today"><text class="summary-value">{{summary.today}}</text><text class="summary-label">今天到期</text></view>
        <view class="summary-item summary-item--upcoming"><text class="summary-value">{{summary.upcoming}}</text><text class="summary-label">即将到期</text></view>
      </view>
      <empty-state wx:if="{{hasLoaded&&!summary.total}}" title="暂无待处理任务" description="今天和未来7天内没有需要处理的到期任务"></empty-state>
      <block wx:else>
        <section-title wx:if="{{sections.overdue.length}}" title="已逾期"></section-title>
        <schedule-task-card wx:for="{{sections.overdue}}" wx:key="_id" item="{{item}}" operating="{{operatingTaskId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card>
        <section-title wx:if="{{sections.today.length}}" title="今天到期"></section-title>
        <schedule-task-card wx:for="{{sections.today}}" wx:key="_id" item="{{item}}" operating="{{operatingTaskId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card>
        <section-title wx:if="{{sections.upcoming.length}}" title="未来7天"></section-title>
        <schedule-task-card wx:for="{{sections.upcoming}}" wx:key="_id" item="{{item}}" operating="{{operatingTaskId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card>
      </block>
    </block>
  </scroll-view>

  <block wx:elif="{{tab==='logs'}}">
    <scroll-view class="filters" scroll-x enhanced show-scrollbar="{{false}}">
      <view wx:for="{{filterOptions}}" wx:key="key" class="filter {{filter===item.key?'on':''}}" data-key="{{item.key}}" bindtap="chooseFilter">{{item.label}}</view>
    </scroll-view>
    <loading-skeleton wx:if="{{loading}}" rows="4"></loading-skeleton>
    <empty-state wx:elif="{{error}}" type="error" title="操作记录加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state>
    <empty-state wx:elif="{{!logs.length&&!loading}}" title="还没有操作记录" description="创建、修改或完成任务后，记录会显示在这里"></empty-state>
    <view wx:else class="activity-timeline">
      <view wx:for="{{dateGroups}}" wx:key="label" class="timeline-group">
        <view class="timeline-date">{{item.label}}</view>
        <view class="timeline-list">
          <view wx:for="{{item.items}}" wx:key="id" class="timeline-item {{item.canNavigate?'navigable':''}}" data-item="{{item}}" bindtap="goToTarget">
            <view class="timeline-dot dot-{{item.tone}}"><view class="dot-inner icon-{{item.icon}}"></view></view>
            <view class="timeline-content">
              <view class="timeline-main"><text class="timeline-title">{{item.label}} </text><text class="timeline-target-name">{{item.title}}</text><view wx:if="{{item.changeText}}" class="timeline-changes"><text>{{item.changeText}}</text></view></view>
              <view class="timeline-right"><text class="timeline-time">{{item.timeText}}</text><view wx:if="{{item.canNavigate}}" class="timeline-arrow"></view></view>
            </view>
          </view>
        </view>
      </view>
      <view wx:if="{{loadingMore}}" class="load-more-indicator"><view class="loading-spinner"></view><text>加载中...</text></view>
      <view wx:elif="{{!hasMore&&logs.length>0}}" class="load-more-indicator load-more-end"><text>没有更多了</text></view>
      <view wx:elif="{{!loadingMore&&error}}" class="load-more-indicator load-more-retry" bindtap="retryLoadMore"><text>加载更多失败，点击重试</text></view>
    </view>
  </block>
</view>
