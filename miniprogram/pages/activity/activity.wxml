<view class="page activity-page"><view class="page-header"><view class="page-header__title">动态</view><view class="page-header__subtitle">集中查看待处理事项和操作记录</view></view><view class="activity-tabs"><view class="activity-tab {{tab==='pending'?'selected':''}}" data-tab="pending" bindtap="chooseTab">待处理</view><view class="activity-tab {{tab==='logs'?'selected':''}}" data-tab="logs" bindtap="chooseTab">操作记录</view></view><scroll-view class="pending-scroll" wx:if="{{tab==='pending'}}" scroll-y enhanced show-scrollbar="{{false}}" refresher-enabled refresher-triggered="{{loading}}" bindrefresherrefresh="onPullDownRefresh"><loading-skeleton wx:if="{{loading}}" rows="4"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="待处理加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><block wx:else><empty-state wx:if="{{!todayTasks.length&&!upcomingTasks.length&&!overdueTasks.length}}" title="目前没有待处理事项" description="保持这个节奏"></empty-state><block wx:else><section-title wx:if="{{overdueTasks.length}}" title="已逾期"></section-title><schedule-task-card wx:for="{{overdueTasks}}" wx:key="_id" item="{{item}}" operating="{{operatingId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card><section-title wx:if="{{todayTasks.length}}" title="今天到期"></section-title><schedule-task-card wx:for="{{todayTasks}}" wx:key="_id" item="{{item}}" operating="{{operatingId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card><section-title wx:if="{{upcomingTasks.length}}" title="未来3天"></section-title><schedule-task-card wx:for="{{upcomingTasks}}" wx:key="_id" item="{{item}}" operating="{{operatingId===item._id}}" bind:open="openTask" bind:toggle="toggleTask"></schedule-task-card></block></block></scroll-view><block wx:elif="{{tab==='logs'}}"><scroll-view class="filters" scroll-x enhanced show-scrollbar="{{false}}"><view wx:for="{{filterOptions}}" wx:key="key" class="filter {{filter===item.key?'on':''}}" data-key="{{item.key}}" bindtap="chooseFilter">{{item.label}}</view></scroll-view><loading-skeleton wx:if="{{loading}}" rows="4"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="操作记录加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><empty-state wx:elif="{{!logs.length&&!loading}}" title="还没有操作记录" description="创建、修改或完成任务后，记录会显示在这里"></empty-state><view wx:else class="activity-timeline"><view wx:for="{{dateGroups}}" wx:key="label" class="timeline-group"><view class="timeline-date">{{item.label}}</view><view class="timeline-list"><view wx:for="{{item.items}}" wx:key="id" class="timeline-item {{item.canNavigate?'navigable':''}}" data-item="{{item}}" bindtap="goToTarget"><view class="timeline-dot dot-{{item.tone}}"><view class="dot-inner icon-{{item.icon}}"></view></view><view class="timeline-content"><view class="timeline-main"><text class="timeline-title">{{item.label}} </text><text class="timeline-target-name">{{item.title}}</text><view wx:if="{{item.changeText}}" class="timeline-changes"><text>{{item.changeText}}</text></view></view><view class="timeline-right"><text class="timeline-time">{{item.timeText}}</text><view wx:if="{{item.canNavigate}}" class="timeline-arrow"></view></view></view></view></view></view><view wx:if="{{loadingMore}}" class="load-more-indicator"><view class="loading-spinner"></view><text>加载中...</text></view><view wx:elif="{{!hasMore&&logs.length>0}}" class="load-more-indicator load-more-end"><text>没有更多了</text></view><view wx:elif="{{!loadingMore&&error}}" class="load-more-indicator load-more-retry" bindtap="retryLoadMore"><text>加载更多失败，点击重试</text></view></view></block></view>