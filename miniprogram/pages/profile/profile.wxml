<view class="page profile-page"><view class="page-header"><view class="page-header__title">我的</view><view class="page-header__subtitle">管理个人数据与使用偏好</view></view><loading-skeleton wx:if="{{loading}}" rows="4"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="个人信息加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><empty-state wx:elif="{{!user}}" title="用户信息未初始化" description="请重新进入小程序后再试" action-text="重新加载" bind:action="retry"></empty-state><block wx:else><view class="user-card"><image wx:if="{{user.avatarUrl}}" class="avatar" src="{{user.avatarUrl}}" mode="aspectFill"></image><view wx:else class="avatar avatar--placeholder"><view class="avatar-head"></view><view class="avatar-body"></view></view><view class="user-copy"><text class="user-name">{{user.nickname}}</text><text class="user-meta">{{joinedText}}</text></view><view class="user-badge">个人版</view></view><section-title title="个人偏好"></section-title><view class="settings-card"><settings-item title="新建分支任务默认提醒" description="仅作为分支任务的默认提醒设置" value="{{reminderText}}" icon="notice" bind:select="chooseReminder"></settings-item><settings-item title="完成任务自动沉底" description="完成后移到当前分组末尾" icon="sink" show-switch="{{true}}" checked="{{user.completedTaskSink}}" disabled="{{savingSetting}}" bind:change="changeSink"></settings-item><settings-item title="默认时区" description="任务时间按当前时区显示" value="{{user.timezone||'Asia/Shanghai'}}" icon="timezone" disabled="{{true}}"></settings-item></view><section-title title="数据管理"></section-title><view class="settings-card"><settings-item title="已归档大事件" description="查看和恢复已归档的大事件" value="{{counts.archived+'个'}}" icon="archive" bind:select="archive"></settings-item><settings-item title="回收站" description="恢复误删的大事件与分支任务" value="{{counts.recycle+'项'}}" icon="recycle" bind:select="recycle"></settings-item></view><section-title title="通知与隐私"></section-title><view class="settings-card"><settings-item title="通知设置" description="查看现有通知配置" icon="notice" bind:select="notifications"></settings-item><settings-item title="隐私说明" description="了解个人数据如何保存" icon="privacy" bind:select="privacy"></settings-item><settings-item title="关于事有进度" description="产品说明与版本信息" icon="default" bind:select="about"></settings-item></view><view class="about-card"><text class="about-name">事有进度</text><text class="about-version">当前版本 v1.0.0</text><text class="about-description">把大事件拆成可以一步步完成的分支任务。</text></view></block></view>
