<view class="page profile-page"><view class="page-header"><view class="page-header__title">我的</view><view class="page-header__subtitle">管理个人数据与使用偏好</view></view><view class="user-card"><image wx:if="{{user.avatarUrl}}" class="avatar" src="{{user.avatarUrl}}" mode="aspectFill"></image><view wx:else class="avatar avatar--placeholder"><view class="avatar-head"></view><view class="avatar-body"></view></view><view class="user-copy"><text class="user-name">{{user.nickname}}</text><text class="user-meta">个人事件空间</text></view><view class="user-badge">个人版</view></view><section-title title="事件管理"></section-title><view class="settings-card"><view class="setting" bindtap="archive"><view class="setting-icon setting-icon--archive"><view class="box-line"></view></view><view class="setting-copy"><text class="setting-title">已归档事件</text><text class="setting-description">查看和恢复已归档的事件</text></view><view class="chevron"></view></view><view class="setting" bindtap="recycle"><view class="setting-icon setting-icon--recycle"><view class="bin-line"></view></view><view class="setting-copy"><text class="setting-title">回收站</text><text class="setting-description">恢复误删的事件与任务</text></view><view class="chevron"></view></view></view><section-title title="偏好设置"></section-title><view class="settings-card"><view class="setting" bindtap="notifications"><view class="setting-icon setting-icon--notice"><view class="bell-line"></view></view><view class="setting-copy"><text class="setting-title">通知设置</text><text class="setting-description">管理提醒与通知偏好</text></view><view class="chevron"></view></view><view class="setting" bindtap="notReady"><view class="setting-icon setting-icon--sink"><view class="sink-line"></view></view><view class="setting-copy"><text class="setting-title">完成任务自动下沉</text><text class="setting-description">已开启</text></view><view class="chevron"></view></view></view><text class="version">事件树 · 个人版</text></view>
