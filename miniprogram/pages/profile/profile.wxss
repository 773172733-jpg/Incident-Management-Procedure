@import '../../styles/variables.wxss';@import '../../styles/common.wxss';
.profile-page{padding-top:env(safe-area-inset-top);padding-bottom:48rpx}
.user-card,.settings-card,.about-card{margin:0 32rpx;border-radius:24rpx;background:#fff;box-shadow:0 6rpx 20rpx rgba(31,35,41,.045)}
.user-card{display:flex;align-items:center;padding:26rpx}
.avatar{width:94rpx;height:94rpx;border-radius:28rpx;background:#FFF1EA;flex-shrink:0}.avatar--placeholder{position:relative}.avatar-head{position:absolute;left:34rpx;top:19rpx;width:28rpx;height:28rpx;border-radius:50%;background:#FFB392}.avatar-body{position:absolute;left:23rpx;bottom:16rpx;width:50rpx;height:28rpx;border-radius:28rpx 28rpx 10rpx 10rpx;background:#FF6B35}
.user-copy{flex:1;min-width:0;margin-left:22rpx}.user-name,.user-meta{display:block}.user-name{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1F2329;font-size:32rpx;font-weight:600}.user-meta{margin-top:8rpx;color:#8A9099;font-size:23rpx}.user-badge{flex-shrink:0;padding:7rpx 15rpx;border-radius:999rpx;background:#FFF1EA;color:#FF6B35;font-size:20rpx}
.settings-card{padding:0 20rpx}
.about-card{margin-top:36rpx;padding:25rpx 28rpx;text-align:center;box-shadow:none;background:rgba(255,255,255,.72)}
.about-name,.about-version,.about-description{display:block}.about-name{color:#1F2329;font-size:27rpx;font-weight:600}.about-version{margin-top:6rpx;color:#8A9099;font-size:21rpx}.about-description{margin-top:13rpx;color:#737B86;font-size:22rpx}
