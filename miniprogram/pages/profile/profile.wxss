@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.profile-page{padding-top:env(safe-area-inset-top)}.user-card,.settings-card{margin:0 32rpx;padding:28rpx;border-radius:30rpx;background:#fff;box-shadow:var(--shadow-card)}.user-card{display:flex;align-items:center}.avatar{width:94rpx;height:94rpx;border-radius:30rpx;background:#FFF1EA}.avatar--placeholder{position:relative}.avatar-head{position:absolute;left:34rpx;top:19rpx;width:28rpx;height:28rpx;border-radius:50%;background:#FFB392}.avatar-body{position:absolute;left:23rpx;bottom:16rpx;width:50rpx;height:28rpx;border-radius:28rpx 28rpx 10rpx 10rpx;background:#FF6B35}.user-copy{flex:1;margin-left:22rpx}.user-name,.user-meta{display:block}.user-name{color:#1F2329;font-size:32rpx;font-weight:600}.user-meta{margin-top:8rpx;color:#8A9099;font-size:23rpx}.user-badge{padding:7rpx 15rpx;border-radius:999rpx;background:#FFF1EA;color:#FF6B35;font-size:20rpx}.settings-card{padding-top:0;padding-bottom:0}.setting{display:flex;align-items:center;padding:26rpx 0;border-bottom:1rpx solid #EEF0F3}.setting:last-child{border-bottom:0}.setting-icon{position:relative;width:70rpx;height:70rpx;border-radius:22rpx;background:#FFF1EA;color:#FF6B35}.setting-icon--recycle{background:#FFF0F0;color:#F04A4A}.setting-icon--notice{background:#EEF4FF;color:#4E8DF5}.setting-icon--sink{background:#EBF8F1;color:#22B573}.box-line,.bin-line,.bell-line,.sink-line{position:absolute;left:20rpx;right:20rpx;top:22rpx;bottom:19rpx;border:4rpx solid currentColor;border-radius:5rpx}.bin-line{top:25rpx}.bell-line{border-radius:18rpx 18rpx 8rpx 8rpx}.sink-line{height:4rpx;top:33rpx;bottom:auto;border:0;background:currentColor;box-shadow:0 11rpx 0 currentColor}.setting-copy{flex:1;margin-left:20rpx}.setting-title,.setting-description{display:block}.setting-title{color:#1F2329;font-size:28rpx;font-weight:500}.setting-description{margin-top:6rpx;color:#8A9099;font-size:22rpx}.chevron{width:14rpx;height:14rpx;border-top:3rpx solid #B8BEC7;border-right:3rpx solid #B8BEC7;transform:rotate(45deg)}.version{display:block;margin-top:52rpx;text-align:center;color:#B8BEC7;font-size:21rpx}
