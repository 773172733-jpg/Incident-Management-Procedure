@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.settings-card,.info-card{margin:0 32rpx;padding:0 28rpx;border-radius:30rpx;background:#fff;box-shadow:var(--shadow-card)}.info-card{display:flex;align-items:center;padding-top:27rpx;padding-bottom:27rpx}.info-icon{position:relative;width:70rpx;height:70rpx;border-radius:21rpx;background:#F1F2F4;color:#8A9099;flex-shrink:0}.info-icon--active{background:#EBF8F1;color:#22B573}.info-mark{position:absolute;left:21rpx;right:21rpx;top:20rpx;bottom:20rpx;border:4rpx solid currentColor;border-radius:50%}.info-copy{flex:1;min-width:0;margin-left:20rpx}.info-title,.info-description{display:block}.info-title{color:#1F2329;font-size:27rpx;font-weight:600}.info-description{margin-top:7rpx;color:#8A9099;font-size:21rpx;line-height:1.55}.available,.unavailable{margin-left:14rpx;padding:5rpx 11rpx;border-radius:999rpx;background:#EBF8F1;color:#22B573;font-size:18rpx;flex-shrink:0}.unavailable{background:#F1F2F4;color:#8A9099}.notice{margin:38rpx 44rpx;color:#8A9099;font-size:21rpx;line-height:1.7}
