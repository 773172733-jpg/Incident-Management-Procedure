<view class="page notification-page">
  <view class="page-header">
    <text class="page-header__title">通知设置</text>
    <text class="page-header__subtitle">管理新任务的默认提醒方式</text>
  </view>
  <loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton>
  <empty-state wx:elif="{{error}}" type="error" title="通知设置加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state>
  <empty-state wx:elif="{{!user}}" title="暂无通知设置" description="请完成用户初始化后重试"></empty-state>
  <block wx:else>
    <section-title title="默认提醒"></section-title>
    <view class="settings-card">
      <settings-item title="新任务默认提醒" description="只影响之后新建的有时间任务" value="{{reminderText}}" icon="notice" disabled="{{saving}}" bind:select="chooseReminder"></settings-item>
    </view>
    <section-title title="小程序内提醒"></section-title>
    <view class="info-card">
      <view class="info-icon info-icon--active"><view class="info-mark"></view></view>
      <view class="info-copy"><text class="info-title">动态页提醒</text><text class="info-description">提醒到点后会出现在动态页，可逐条或全部标为已读。</text></view>
      <text class="available">可用</text>
    </view>
    <section-title title="微信订阅消息"></section-title>
    <view class="info-card">
      <view class="info-icon info-icon--active"><view class="info-mark"></view></view>
      <view class="info-copy"><text class="info-title">微信服务通知</text><text class="info-description">需要在设置任务提醒时由你主动授权；拒绝授权不影响小程序内提醒。</text></view>
      <text class="available">按次授权</text>
    </view>
  </block>
</view>
