<view class="page archive-page"><view class="page-header"><text class="page-header__title">已归档事件</text><text class="page-header__subtitle">归档不会删除数据，可以随时恢复</text></view><loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="归档列表加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><empty-state wx:elif="{{!items.length}}" title="暂无已归档事件" description="归档的事件会集中显示在这里"></empty-state><view wx:else class="archive-list"><list-project-card wx:for="{{items}}" wx:key="_id" item="{{item}}" show-progress="{{true}}" primary-text="恢复" secondary-text="移到回收站" bind:primary="restore" bind:secondary="remove"></list-project-card></view></view>
