<view class="page"><view class="page-header"><text class="page-header__title">已归档事件</text><text class="page-header__subtitle">归档不会删除数据，可以随时恢复</text></view><loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><empty-state wx:elif="{{!items.length}}" title="暂无归档事件" description="暂时收起的事件会显示在这里"></empty-state><view wx:else class="archive-list"><view wx:for="{{items}}" wx:key="_id" class="archive-card"><view class="archive-icon"><view class="archive-line"></view></view><view class="archive-copy"><text class="archive-title">{{item.title}}</text><text class="archive-meta">{{item.timeText}} · 已完成 {{item.completedTaskCountCache||0}}/{{item.taskCountCache||0}}</text></view><button class="restore" data-id="{{item._id}}" bindtap="restore">恢复</button></view></view></view>
