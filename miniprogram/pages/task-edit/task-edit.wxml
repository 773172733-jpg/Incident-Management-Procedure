<view class="page form-page">
  <view class="page-header">
    <text class="page-header__title">{{editMode?'编辑分支任务':'新建分支任务'}}</text>
    <text class="page-header__subtitle">把任务信息整理清楚，执行会更轻松</text>
  </view>
  <loading-skeleton wx:if="{{loading}}" rows="4"></loading-skeleton>
  <empty-state wx:elif="{{error}}" type="error" title="表单加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state>
  <block wx:else>
    <section-title title="基础信息"></section-title>
    <view class="form-card">
      <view class="field {{focusedField==='title'?'field--focused':''}}">
        <text class="label">分支任务名称</text>
        <input class="input" placeholder="输入分支任务名称" value="{{title}}" data-key="title" bindinput="onInput" bindfocus="onFocus" bindblur="onBlur" maxlength="60"/>
        <text class="counter counter--inline">{{title.length}}/60</text>
      </view>
    </view>

    <section-title title="所属分组"></section-title>
    <scroll-view scroll-x class="group-picker" enhanced show-scrollbar="{{false}}">
      <view class="group-chip {{groupId===''?'selected':''}}" data-id="" bindtap="chooseGroup">未分组</view>
      <view wx:for="{{groups}}" wx:key="_id" class="group-chip {{groupId===item._id?'selected':''}}" data-id="{{item._id}}" bindtap="chooseGroup">{{item.name}}</view>
      <view class="group-chip group-chip--new" bindtap="createGroup"><view class="small-plus"></view>新建分组</view>
    </scroll-view>

    <section-title title="任务等级"></section-title>
    <view class="priority-card">
      <view class="priority-option {{priority==='core'?'selected':''}}" data-value="core" bindtap="pickPriority"><view class="priority-dot priority-dot--core"></view><view class="priority-copy"><text class="priority-name">核心任务</text><text class="priority-description">必须优先完成</text></view><view class="radio"></view></view>
      <view class="priority-option {{priority==='important'?'selected':''}}" data-value="important" bindtap="pickPriority"><view class="priority-dot priority-dot--important"></view><view class="priority-copy"><text class="priority-name">重要任务</text><text class="priority-description">建议优先完成</text></view><view class="radio"></view></view>
      <view class="priority-option {{priority==='optional'?'selected':''}}" data-value="optional" bindtap="pickPriority"><view class="priority-dot priority-dot--optional"></view><view class="priority-copy"><text class="priority-name">可选任务</text><text class="priority-description">有时间再完成</text></view><view class="radio"></view></view>
    </view>

    <section-title title="时间设置"></section-title>
    <view class="form-card">
      <view class="mode-row"><view class="mode-item {{scheduleType==='none'?'active':''}}" data-mode="none" bindtap="onSwitchMode">不设置</view><view class="mode-item {{scheduleType==='deadline'?'active':''}}" data-mode="deadline" bindtap="onSwitchMode">截止时间</view><view class="mode-item {{scheduleType==='range'?'active':''}}" data-mode="range" bindtap="onSwitchMode">起止期间</view></view>
      <text wx:if="{{scheduleType==='none'}}" class="time-hint">不设置时间的任务不会出现在日历中</text>
      <view wx:if="{{scheduleType==='deadline'}}" class="date-pair"><view class="date-cell"><text class="label">截止日期</text><picker mode="date" value="{{dueAt}}" data-key="dueAt" bindchange="onPickDate"><view class="date-value {{dueAt?'':'muted'}}">{{dueAt||'请选择'}}</view></picker></view><view class="date-cell"><text class="label">截止时间</text><picker mode="time" value="{{dueTime}}" data-key="dueTime" bindchange="onPickTime"><view class="date-value">{{dueTime||'00:00'}}</view></picker></view></view>
      <block wx:if="{{scheduleType==='range'}}">
        <view class="date-pair"><view class="date-cell"><text class="label">开始日期</text><picker mode="date" value="{{startAt}}" data-key="startAt" bindchange="onPickDate"><view class="date-value {{startAt?'':'muted'}}">{{startAt||'请选择'}}</view></picker></view><view class="date-cell"><text class="label">开始时间</text><picker mode="time" value="{{startTime}}" data-key="startTime" bindchange="onPickTime"><view class="date-value">{{startTime||'09:00'}}</view></picker></view></view>
        <view class="date-pair"><view class="date-cell"><text class="label">结束日期</text><picker mode="date" value="{{endAt}}" start="{{startAt}}" data-key="endAt" bindchange="onPickDate"><view class="date-value {{endAt?'':'muted'}}">{{endAt||'请选择'}}</view></picker></view><view class="date-cell"><text class="label">结束时间</text><picker mode="time" value="{{endTime}}" data-key="endTime" bindchange="onPickTime"><view class="date-value">{{endTime||'18:00'}}</view></picker></view></view>
        <text wx:if="{{timeError}}" class="time-error">{{timeError}}</text>
      </block>
    </view>

    <section-title title="提醒设置"></section-title>
    <view class="form-card reminder-card {{scheduleType==='none'?'reminder-card--disabled':''}}">
      <text wx:if="{{scheduleType==='none'}}" class="reminder-disabled-text">设置截止时间后才能开启提醒</text>
      <view class="reminder-options"><view wx:for="{{reminderOptions}}" wx:key="label" class="reminder-option {{reminderMode===item.mode&&(item.mode!=='offset'||reminderOffsetMinutes===item.minutes)?'selected':''}}" data-mode="{{item.mode}}" data-minutes="{{item.minutes}}" bindtap="pickReminder">{{item.label}}</view></view>
      <view wx:if="{{scheduleType!=='none'&&reminderMode==='custom'}}" class="date-pair reminder-custom"><view class="date-cell"><text class="label">提醒日期</text><picker mode="date" value="{{reminderCustomDate}}" data-key="reminderCustomDate" bindchange="onPickDate"><view class="date-value {{reminderCustomDate?'':'muted'}}">{{reminderCustomDate||'请选择'}}</view></picker></view><view class="date-cell"><text class="label">提醒时间</text><picker mode="time" value="{{reminderCustomTime}}" data-key="reminderCustomTime" bindchange="onPickTime"><view class="date-value">{{reminderCustomTime||'09:00'}}</view></picker></view></view>
      <view wx:if="{{scheduleType!=='none'&&reminderMode!=='none'}}" class="reminder-channel">
        <view class="channel-copy"><text class="channel-title">提醒方式</text><text class="channel-desc">小程序内提醒默认保留，微信服务通知需要保存时授权。</text></view>
        <view class="channel-row"><text>小程序内提醒</text><text class="channel-fixed">已开启</text></view>
        <label class="channel-row channel-row--switch"><text>微信服务通知</text><switch checked="{{wechatReminderEnabled}}" color="#FF6B35" bindchange="toggleWechatReminder"/></label>
      </view>
    </view>

    <section-title title="任务备注"></section-title>
    <view class="form-card"><view class="field {{focusedField==='note'?'field--focused':''}}"><textarea class="textarea" placeholder="补充分支任务说明，可选" value="{{note}}" data-key="note" bindinput="onInput" bindfocus="onFocus" bindblur="onBlur" maxlength="500"/><text class="counter">{{note.length}}/500</text></view></view>
    <bottom-action-bar text="{{editMode?'保存修改':'保存'}}" loading="{{saving}}" disabled="{{saving}}" bind:action="onSave"></bottom-action-bar>
  </block>
</view>
