<view class="page form-page"><view class="page-header"><text class="page-header__title">{{editMode?'编辑任务':'添加任务'}}</text><text class="page-header__subtitle">把任务信息整理清楚，执行会更轻松</text></view><loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="表单加载失败" description="{{error}}"></empty-state><block wx:else><section-title title="基本信息"></section-title><view class="form-card"><view class="field"><text class="label">任务名称</text><input class="input" placeholder="输入任务名称" value="{{title}}" data-key="title" bindinput="onInput" maxlength="60"/></view><view class="field"><text class="label">所属分组</text><picker range="{{groups}}" range-key="name" value="{{groupIndex}}" bindchange="onPickGroup"><view class="picker-value"><text class="value {{groupId?'':'muted'}}">{{groupName}}</text><view class="chevron"></view></view></picker></view></view><section-title title="任务等级"></section-title><view class="priority-card"><view class="priority-option {{priority==='core'?'selected':''}}" data-value="core" bindtap="pickPriority"><view class="priority-dot priority-dot--core"></view><view><text class="priority-name">核心任务</text><text class="priority-description">必须完成的任务</text></view><view class="radio"></view></view><view class="priority-option {{priority==='important'?'selected':''}}" data-value="important" bindtap="pickPriority"><view class="priority-dot priority-dot--important"></view><view><text class="priority-name">重要任务</text><text class="priority-description">建议优先完成</text></view><view class="radio"></view></view><view class="priority-option {{priority==='optional'?'selected':''}}" data-value="optional" bindtap="pickPriority"><view class="priority-dot priority-dot--optional"></view><view><text class="priority-name">可选任务</text><text class="priority-description">有时间再完成</text></view><view class="radio"></view></view></view><section-title title="时间设置"></section-title><view class="form-card"><view class="mode-row"><view class="mode-item {{scheduleType==='none'?'active':''}}" data-mode="none" bindtap="onSwitchMode">不设置</view><view class="mode-item {{scheduleType==='deadline'?'active':''}}" data-mode="deadline" bindtap="onSwitchMode">截止时间</view><view class="mode-item {{scheduleType==='range'?'active':''}}" data-mode="range" bindtap="onSwitchMode">起止期间</view></view><view wx:if="{{scheduleType==='deadline'}}" class="field date-field"><text class="label">截止日期</text><picker mode="date" value="{{dueAt}}" data-key="dueAt" bindchange="onPickDate"><view class="picker-value"><text class="value {{dueAt?'':'muted'}}">{{dueAt||'请选择截止日期'}}</text><view class="chevron"></view></view></picker></view><view wx:if="{{scheduleType==='range'}}" class="date-grid"><view class="date-cell"><text class="label">开始日期</text><picker mode="date" value="{{startAt}}" data-key="startAt" bindchange="onPickDate"><view class="date-value">{{startAt||'请选择'}}</view></picker></view><view class="date-cell"><text class="label">结束日期</text><picker mode="date" value="{{endAt}}" start="{{startAt}}" data-key="endAt" bindchange="onPickDate"><view class="date-value">{{endAt||'请选择'}}</view></picker></view></view></view><section-title title="任务备注"></section-title><view class="form-card"><textarea class="textarea" placeholder="输入任务备注（可选）" value="{{note}}" data-key="note" bindinput="onInput" maxlength="500"/><text class="counter">{{note.length}}/500</text></view><bottom-action-bar text="{{editMode?'保存修改':'保存任务'}}" loading="{{saving}}" disabled="{{saving}}" bind:action="onSave"></bottom-action-bar></block></view>
