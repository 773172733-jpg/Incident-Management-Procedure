@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.form-page{padding-bottom:calc(160rpx + env(safe-area-inset-bottom))}.form-card,.priority-card{margin:0 32rpx;padding:0 28rpx;border-radius:30rpx;background:#fff;box-shadow:var(--shadow-card)}.field{position:relative;padding:28rpx 0}.field--focused::after{content:'';position:absolute;left:0;right:0;bottom:0;height:3rpx;border-radius:3rpx;background:#FFB18E}.label{display:block;margin-bottom:14rpx;color:#59606A;font-size:24rpx;font-weight:500}.input{height:64rpx;padding-right:80rpx;color:#1F2329;font-size:29rpx}.counter{display:block;padding-bottom:4rpx;text-align:right;color:#B8BEC7;font-size:20rpx}.counter--inline{position:absolute;right:0;bottom:47rpx}.group-picker{box-sizing:border-box;width:100%;height:78rpx;padding:0 32rpx;white-space:nowrap}.group-chip{display:inline-flex;align-items:center;height:60rpx;padding:0 25rpx;margin-right:14rpx;border:2rpx solid transparent;border-radius:999rpx;background:#fff;color:#8A9099;font-size:23rpx;vertical-align:top}.group-chip.selected{border-color:#FFB18E;background:#FFF1EA;color:#FF6B35;font-weight:600}.group-chip--new{border-color:#FFDBCA;color:#FF6B35}.small-plus{position:relative;width:20rpx;height:20rpx;margin-right:8rpx}.small-plus::before,.small-plus::after{content:'';position:absolute;left:8rpx;top:1rpx;width:4rpx;height:18rpx;border-radius:4rpx;background:#FF6B35}.small-plus::after{transform:rotate(90deg)}.priority-option{position:relative;display:flex;align-items:center;padding:28rpx 0;border-bottom:1rpx solid #EEF0F3}.priority-option:last-child{border-bottom:0}.priority-dot{width:20rpx;height:20rpx;margin-right:22rpx;border-radius:50%}.priority-dot--core{background:#F04A4A}.priority-dot--important{background:#F6B90A}.priority-dot--optional{background:#C9CDD2}.priority-copy{flex:1}.priority-name,.priority-description{display:block}.priority-name{color:#1F2329;font-size:28rpx;font-weight:500}.priority-description{margin-top:6rpx;color:#8A9099;font-size:22rpx}.radio{width:34rpx;height:34rpx;border:3rpx solid #D9DDE2;border-radius:50%}.priority-option.selected .radio{border:10rpx solid #FF6B35;box-sizing:border-box}.mode-row{display:flex;gap:14rpx;padding:28rpx 0}.mode-item{flex:1;height:70rpx;border-radius:20rpx;background:#F7F8FA;color:#8A9099;text-align:center;font-size:23rpx;line-height:70rpx}.mode-item.active{background:#FFF1EA;color:#FF6B35;font-weight:600}.date-pair{display:flex;gap:18rpx;padding-bottom:24rpx}.date-cell{flex:1;padding:20rpx;border-radius:20rpx;background:#F7F8FA}.date-value{color:#1F2329;font-size:24rpx}.muted{color:#B8BEC7}.time-error{display:block;padding:0 0 24rpx;color:#F04A4A;font-size:21rpx}.textarea{width:100%;min-height:190rpx;color:#1F2329;font-size:28rpx;box-sizing:border-box}
.time-hint{display:block;margin-top:10rpx;color:#8A9099;font-size:20rpx;line-height:28rpx}
.reminder-card{padding-top:20rpx;padding-bottom:20rpx}.reminder-card--disabled{opacity:.58}.reminder-disabled-text{display:block;margin-bottom:14rpx;color:#8A9099;font-size:21rpx}.reminder-options{display:flex;flex-wrap:wrap;gap:14rpx}.reminder-option{box-sizing:border-box;padding:14rpx 20rpx;border:2rpx solid #EEF0F3;border-radius:18rpx;background:#F7F8FA;color:#59606A;font-size:22rpx}.reminder-option.selected{border-color:#FFB18E;background:#FFF1EA;color:#FF6B35;font-weight:600}.reminder-card--disabled .reminder-option{pointer-events:none}.reminder-custom{padding-top:22rpx;padding-bottom:0}
