@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.form-page{padding-bottom:calc(150rpx + env(safe-area-inset-bottom))}.form-card,.priority-card{margin:0 32rpx;padding:0 28rpx;border-radius:28rpx;background:#fff;box-shadow:var(--shadow-card)}.field{padding:28rpx 0;border-bottom:1rpx solid #EEF0F3}.field:last-child{border-bottom:0}.label{display:block;margin-bottom:14rpx;color:#59606A;font-size:24rpx;font-weight:500}.input{height:64rpx;color:#1F2329;font-size:29rpx}.picker-value{display:flex;align-items:center;justify-content:space-between;min-height:52rpx}.value{color:#1F2329;font-size:28rpx}.muted{color:#B8BEC7}.chevron{width:14rpx;height:14rpx;border-top:3rpx solid #B8BEC7;border-right:3rpx solid #B8BEC7;transform:rotate(45deg)}.priority-option{position:relative;display:flex;align-items:center;padding:28rpx 0;border-bottom:1rpx solid #EEF0F3}.priority-option:last-child{border-bottom:0}.priority-dot{width:20rpx;height:20rpx;margin-right:22rpx;border-radius:50%}.priority-dot--core{background:#F04A4A}.priority-dot--important{background:#F6B90A}.priority-dot--optional{background:#C9CDD2}.priority-name,.priority-description{display:block}.priority-name{color:#1F2329;font-size:28rpx;font-weight:500}.priority-description{margin-top:6rpx;color:#8A9099;font-size:22rpx}.radio{position:absolute;right:0;width:34rpx;height:34rpx;border:3rpx solid #D9DDE2;border-radius:50%}.priority-option.selected .radio{border:10rpx solid #FF6B35;box-sizing:border-box}.mode-row{display:flex;gap:14rpx;padding:28rpx 0}.mode-item{flex:1;height:70rpx;border-radius:20rpx;background:#F7F8FA;color:#8A9099;text-align:center;font-size:23rpx;line-height:70rpx}.mode-item.active{background:#FFF1EA;color:#FF6B35;font-weight:600}.date-field{border-top:1rpx solid #EEF0F3}.date-grid{display:flex;gap:20rpx;padding:0 0 28rpx}.date-cell{flex:1;padding:20rpx;border-radius:20rpx;background:#F7F8FA}.date-value{color:#1F2329;font-size:24rpx}.textarea{width:100%;min-height:180rpx;padding:28rpx 0;color:#1F2329;font-size:28rpx;box-sizing:border-box}.counter{display:block;padding-bottom:20rpx;text-align:right;color:#B8BEC7;font-size:21rpx}
