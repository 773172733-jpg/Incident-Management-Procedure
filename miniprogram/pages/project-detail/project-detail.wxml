<view class="page" wx:if="{{project}}"><view class="card"><view class="head"><text class="title">{{project.title}}</text><text class="edit" bindtap="edit">编辑</text></view><text class="sub">{{project.timeMode==='none'?'未设置时间':'进行中'}}</text></view><view class="card"><text class="percent">{{project.progressCache||0}}%</text><text class="sub">已完成 {{project.completedTaskCountCache||0}}/{{project.taskCountCache||0}}</text><view class="bar"><view class="bar-in" style="width:{{project.progressCache||0}}%"></view></view></view><scroll-view scroll-x class="tabs"><text class="tab" data-id="all" bindtap="group">全部</text><text wx:for="{{groups}}" wx:key="_id" class="tab" data-id="{{item._id}}" bindtap="group">{{item.name}}</text></scroll-view><view class="priorities"><text wx:for="{{['all','core','important','optional']}}" wx:key="*this" class="tag" data-id="{{item}}" bindtap="priority">{{item==='all'?'全部':item==='core'?'核心':item==='important'?'重要':'可选'}}</text></view><view wx:for="{{tasks}}" wx:key="_id" wx:if="{{(groupId==='all'||item.groupId===groupId)&&(priority==='all'||item.priority===priority)}}" class="card task {{item.status==='completed'?'done':''}}"><view bindtap="add"><text class="tag tag-{{item.priority}}">{{item.priorityText}}</text><text class="task-title">{{item.title}}</text><text class="sub">{{item.note||item.timeText}}</text></view><button class="check" data-item="{{item}}" bindtap="toggle">{{item.status==='completed'?'重开':'完成'}}</button></view><button class="bottom" bindtap="add">添加任务</button></view>
