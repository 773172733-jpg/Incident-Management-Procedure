<view class="page detail-page"><view class="detail-nav" style="{{navStyle}}"><view class="back" bindtap="back"><view class="back-arrow"></view></view><text class="nav-title">{{project?project.title:''}}</text><button class="nav-more" bindtap="showProjectMenu"><view class="nav-dot"></view><view class="nav-dot"></view><view class="nav-dot"></view></button></view><loading-skeleton wx:if="{{loading}}" rows="4"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="任务加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><block wx:elif="{{project}}"><view class="summary-card"><view class="summary-icon" style="color:{{project.themeColor||'#FF6B35'}}">{{project.iconText}}</view><view class="summary-main"><view class="summary-title-row"><text class="summary-title">{{project.title}}</text><text class="status">{{project.statusText}}</text></view><text class="summary-time">{{project.timeText}}</text><text wx:if="{{project.description}}" class="summary-description">{{project.description}}</text><view class="summary-edit" bindtap="edit"><text class="summary-edit__icon">✎</text><text>编辑事件</text></view></view></view><progress-card progress="{{project.progressCache}}" completed="{{project.completedTaskCountCache||0}}" total="{{project.taskCountCache||0}}" nearest="{{project.nearestTaskText}}" color="{{project.themeColor||'#FF6B35'}}"></progress-card><scroll-view scroll-x class="group-tabs" enhanced show-scrollbar="{{false}}"><filter-chip wx:for="{{groupTabs}}" wx:key="value" label="{{item.label}}" value="{{item.value}}" count="{{item.count}}" selected="{{groupId===item.value}}" bind:select="selectGroup"></filter-chip><view class="manage-chip" bindtap="manageGroups"><view class="manage-plus"></view><text>管理分组</text></view></scroll-view><view class="task-section"><text class="task-heading">任务列表</text><scroll-view scroll-x class="priority-scroll" enhanced show-scrollbar="{{false}}"><filter-chip wx:for="{{priorityOptions}}" wx:key="value" label="{{item.label}}" value="{{item.value}}" tone="{{item.tone}}" selected="{{priority===item.value}}" bind:select="selectPriority"></filter-chip></scroll-view></view><empty-state wx:if="{{!tasks.length}}" title="还没有分支任务" description="把大事件拆成可以一步步完成的小任务" action-text="添加第一个任务" bind:action="add"></empty-state><empty-state wx:elif="{{!filteredTasks.length}}" title="当前筛选下没有任务" description="清除筛选后查看全部任务" action-text="清除筛选" bind:action="clearFilters"></empty-state><view wx:else class="task-list"><task-item wx:for="{{filteredTasks}}" wx:for-item="tsk" wx:key="_id" taskData="{{tsk}}" operating="{{operatingTaskId===tsk._id}}" sorting="{{sorting}}" bind:edit="editTask" bind:toggle="toggleTask" bind:more="showTaskMenu"></task-item></view><block wx:if="{{project.status==='active'}}"><view class="action-bar"><view class="action-bar__btn action-bar__btn--primary" bindtap="add"><text class="action-bar__icon">＋</text>添加任务</view><view class="action-bar__btn action-bar__btn--secondary" bindtap="completeProject">结束事件</view></view></block><block wx:elif="{{project.status==='completed'}}"><view class="action-bar"><view class="action-bar__btn action-bar__btn--primary" bindtap="reopenProject">重新打开</view></view></block></block></view>

