<view class="page detail-page"><view class="detail-nav"><view class="back" bindtap="back"><view class="back-arrow"></view></view><text>事件详情</text><view class="nav-space"></view></view><loading-skeleton wx:if="{{loading}}" rows="4"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><block wx:elif="{{project}}"><view class="summary-card"><view class="summary-icon" style="color:{{project.themeColor||'#FF6B35'}};background:{{project.themeColor||'#FF6B35'}}1A">{{project.iconText}}</view><view class="summary-main"><view class="summary-title-row"><text class="summary-title">{{project.title}}</text><text class="status">{{project.statusText}}</text></view><text class="summary-time">{{project.timeText}}</text></view><button class="text-button" bindtap="edit">编辑</button></view><view class="progress-card"><view class="progress-copy"><text class="progress-label">事件进度</text><text class="progress-number">{{project.progressCache || 0}}%</text></view><view class="progress-meta"><text>已完成 {{project.completedTaskCountCache || 0}} / {{project.taskCountCache || 0}} 个任务</text><text wx:if="{{project.taskCountCache>0&&project.progressCache===100}}" class="progress-complete">全部任务已完成</text></view><view class="progress-track"><view class="progress-fill" style="width:{{project.progressCache||0}}%;background:{{project.themeColor||'#FF6B35'}}"></view></view></view><scroll-view scroll-x class="group-tabs" enhanced show-scrollbar="{{false}}"><view class="group-tab {{groupId==='all'?'selected':''}}" data-id="all" bindtap="group">全部</view><view class="group-tab {{groupId===''?'selected':''}}" data-id="" bindtap="group">未分组</view><view wx:for="{{groups}}" wx:key="_id" class="group-tab {{groupId===item._id?'selected':''}}" data-id="{{item._id}}" bindtap="group">{{item.name}}</view><view class="group-tab group-tab--manage" bindtap="manageGroups">管理分组</view></scroll-view><view class="task-header"><text class="task-heading">任务列表</text><view class="priority-filters"><text class="priority-chip {{priority==='all'?'selected':''}}" data-id="all" bindtap="priority">全部</text><text class="priority-chip {{priority==='core'?'selected':''}}" data-id="core" bindtap="priority">核心</text><text class="priority-chip {{priority==='important'?'selected':''}}" data-id="important" bindtap="priority">重要</text><text class="priority-chip {{priority==='optional'?'selected':''}}" data-id="optional" bindtap="priority">可选</text></view></view><empty-state wx:if="{{!filteredTasks.length}}" title="暂无任务" description="当前筛选条件下还没有任务" action-text="添加任务" bind:action="add"></empty-state><view wx:for="{{filteredTasks}}" wx:key="_id" class="task-card {{item.status==='completed'||item.status==='approved'?'task-card--done':''}}"><view class="task-main" data-id="{{item._id}}" bindtap="editTask"><view class="task-title-row"><text class="priority priority--{{item.priority}}">{{item.priorityText}}</text><text class="task-title">{{item.title}}</text></view><text class="task-note">{{item.note||item.timeText||'未设置时间'}}</text><text wx:if="{{item.completedText}}" class="completed-time">{{item.completedText}}</text></view><view class="task-actions"><button class="complete-button {{item.status==='completed'||item.status==='approved'?'is-done':''}}" loading="{{operatingTaskId===item._id}}" data-item="{{item}}" bindtap="toggle"><view class="check-mark"></view></button><view wx:if="{{groupId!=='all'}}" class="order-actions"><button disabled="{{sorting}}" data-id="{{item._id}}" data-direction="-1" bindtap="moveTask">上移</button><button disabled="{{sorting}}" data-id="{{item._id}}" data-direction="1" bindtap="moveTask">下移</button></view><text class="delete-action" data-item="{{item}}" bindtap="deleteTask">删除</text></view></view><bottom-action-bar text="添加任务" bind:action="add"></bottom-action-bar></block></view>
