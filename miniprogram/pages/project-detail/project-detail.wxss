/* 事件详情页 */
@import '../../styles/variables.wxss';
@import '../../styles/common.wxss';

/* 事件头部 */
.head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.title {
  font-size: 20px;
  font-weight: var(--weight-bold);
  color: var(--text-primary);
}
.edit {
  color: var(--primary);
  font-size: 13px;
  padding: 4px 8px;
}
.sub {
  display: block;
  color: var(--text-secondary);
  font-size: 12px;
  margin-top: 8px;
}

/* 进度 */
.percent {
  font-size: 30px;
  font-weight: var(--weight-bold);
  color: var(--primary);
}
.all-done {
  display: block;
  color: var(--success);
  font-size: 13px;
  margin-top: 10px;
}
.bar {
  height: 7px;
  background: var(--divider);
  border-radius: 99px;
  margin-top: 12px;
  overflow: hidden;
}
.bar-in {
  height: 7px;
  background: var(--primary);
  border-radius: 99px;
  transition: width 0.3s ease;
}

/* 分组标签 */
.tabs {
  white-space: nowrap;
  padding: 0 16px 12px;
}
.tab {
  display: inline-block;
  margin-right: 8px;
  padding: 7px 11px;
  background: var(--card-bg);
  border-radius: 99px;
  font-size: 12px;
  color: var(--text-secondary);
}
.tab.selected {
  background: var(--primary-light) !important;
  color: var(--primary);
  font-weight: var(--weight-medium);
}
.tab.manage {
  color: var(--primary);
  border: 1px solid var(--primary-light);
}

/* 优先级筛选 */
.priorities {
  white-space: nowrap;
  padding: 0 16px 12px;
}
.priorities .tag {
  display: inline-block;
  margin-right: 8px;
  padding: 6px 10px;
  background: var(--card-bg);
  border-radius: 99px;
  font-size: 11px;
  color: var(--text-secondary);
}
.priorities .tag.selected {
  background: var(--primary-light) !important;
  color: var(--primary);
}

/* 任务卡片 */
.task {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 14px 16px;
  margin: 0 16px 8px;
  background: var(--card-bg);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}
.task-main {
  flex: 1;
  min-width: 0;
}
.task-title {
  display: block;
  font-size: 15px;
  color: var(--text-primary);
  margin-top: 6px;
  line-height: 1.4;
}
.completed-time {
  display: block;
  color: var(--success);
  font-size: 11px;
  margin-top: 6px;
}

/* 优先级标签 */
.tag {
  display: inline-block;
  font-size: 11px;
  padding: 2px 8px;
  border-radius: var(--radius-tag);
  font-weight: var(--weight-medium);
}
.tag-core {
  background: #FDE8E8;
  color: #F04A4A;
}
.tag-important {
  background: #FDF6E0;
  color: #B8860B;
}
.tag-optional {
  background: #F0F1F3;
  color: var(--text-secondary);
}

/* 已完成任务 */
.task.done {
  opacity: 0.6;
}
.task.done .task-title {
  text-decoration: line-through;
  color: var(--text-secondary);
}

/* 操作按钮区 */
.task-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  margin-left: 12px;
  flex-shrink: 0;
}
.task-actions .check {
  color: var(--primary);
  background: var(--primary-light);
  border-radius: 18px;
  font-size: 12px;
  padding: 4px 14px;
  line-height: 1.6;
  border: none;
  min-width: 56px;
}
.task-actions .move-row {
  display: flex;
  gap: 2px;
}
.task-actions .move-row button {
  font-size: 10px;
  padding: 2px 5px;
  line-height: 1.6;
  color: var(--text-secondary);
}
.task-actions .delete {
  color: var(--danger);
  font-size: 11px;
  padding: 0;
  background: none;
  border: none;
  line-height: 1.6;
}

/* 空状态 */
.compact {
  padding: 40px 16px;
}

/* 底部添加按钮 */
.bottom {
  position: fixed;
  bottom: 16px;
  left: 16px;
  right: 16px;
  background: var(--primary);
  color: #fff;
  border-radius: var(--radius-btn);
  font-size: 16px;
  font-weight: var(--weight-medium);
  padding: 13px 0;
}
