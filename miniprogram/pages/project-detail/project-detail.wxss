/* project-detail */
@import '../../styles/variables.wxss';
@import '../../styles/common.wxss';
.head,.task{display:flex;justify-content:space-between}.title{font-size:20px;font-weight:600}.edit,.manage{color:#FF6B35}.sub{display:block;color:#8A9099;font-size:12px;margin-top:8px}.percent{font-size:30px;font-weight:700}.all-done{display:block;color:#22B573;font-size:13px;margin-top:10px}.bar{height:7px;background:#EEF0F3;border-radius:99px;margin-top:12px}.bar-in{height:7px;background:#FF6B35;border-radius:99px;transition:width .2s}.tabs,.priorities{white-space:nowrap;padding:0 16px 12px}.tab,.priorities .tag{display:inline-block;margin-right:8px;padding:7px 11px;background:#fff;border-radius:99px;font-size:12px}.selected{background:#FFF1EA!important;color:#FF6B35}.task-main{flex:1;min-width:0}.task-title{display:block;font-size:16px;margin-top:7px}.completed-time{display:block;color:#22B573;font-size:11px;margin-top:6px}.done{opacity:.55}.done .task-title{text-decoration:line-through}.task-actions{width:112px;text-align:right}.check{color:#FF6B35;background:#FFF1EA;border-radius:18px;font-size:12px}.move-row{display:flex;margin-top:6px}.move-row button{font-size:10px;padding:0 6px}.delete{color:#F04A4A;margin-top:6px}.compact{padding:32px}.bottom{position:fixed;bottom:16px;left:16px;right:16px;background:#FF6B35;color:#fff}
