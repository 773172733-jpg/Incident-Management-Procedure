@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.detail-page{padding-bottom:calc(160rpx + env(safe-area-inset-bottom))}.detail-nav{display:flex;align-items:center;box-sizing:content-box;padding-left:32rpx;color:#1F2329}.back{display:flex;align-items:center;justify-content:center;width:68rpx;height:68rpx;margin-left:-16rpx;flex-shrink:0}.back-arrow{width:20rpx;height:20rpx;border-left:4rpx solid #1F2329;border-bottom:4rpx solid #1F2329;transform:rotate(45deg)}.nav-title{flex:1;min-width:0;margin:0 14rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-align:center;font-size:31rpx;font-weight:600}.nav-more{display:flex;align-items:center;justify-content:center;width:66rpx;height:58rpx;margin:0;padding:0;border-radius:29rpx;background:#fff;flex-shrink:0}.nav-dot{width:6rpx;height:6rpx;margin:0 3rpx;border-radius:50%;background:#59606A}.summary-card{display:flex;align-items:flex-start;margin:0 32rpx 24rpx;padding:30rpx;border-radius:32rpx;background:#fff;box-shadow:var(--shadow-card)}.summary-icon{display:flex;align-items:center;justify-content:center;width:90rpx;height:90rpx;border-radius:25rpx;background:#FFF1EA;font-size:34rpx;font-weight:700;flex-shrink:0}.summary-main{flex:1;min-width:0;margin-left:22rpx}.summary-title-row{display:flex;align-items:center}.summary-title{max-width:370rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1F2329;font-size:31rpx;font-weight:600}.status{margin-left:12rpx;padding:5rpx 12rpx;border-radius:999rpx;background:#FFF1EA;color:#FF6B35;font-size:20rpx;flex-shrink:0}.summary-time,.summary-description{display:block;margin-top:10rpx;color:#8A9099;font-size:23rpx}.summary-description{max-width:520rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.group-tabs{box-sizing:border-box;width:100%;height:88rpx;padding:4rpx 32rpx 18rpx;white-space:nowrap}.group-tabs filter-chip{display:inline-block;margin-right:14rpx}.manage-chip{display:inline-flex;align-items:center;height:58rpx;padding:0 22rpx;border:1rpx solid #FFDBCA;border-radius:999rpx;background:#fff;color:#FF6B35;font-size:23rpx;vertical-align:top}.manage-plus{position:relative;width:22rpx;height:22rpx;margin-right:8rpx}.manage-plus::before,.manage-plus::after{content:'';position:absolute;left:9rpx;top:1rpx;width:4rpx;height:20rpx;border-radius:4rpx;background:#FF6B35}.manage-plus::after{transform:rotate(90deg)}.task-section{display:flex;align-items:center;padding:19rpx 0 20rpx 32rpx}.task-heading{font-size:32rpx;font-weight:600;color:#1F2329;flex-shrink:0}.priority-scroll{box-sizing:border-box;flex:1;height:62rpx;margin-left:18rpx;white-space:nowrap}.priority-scroll filter-chip{display:inline-block;margin-right:8rpx}.task-list{padding-bottom:12rpx}
.action-bar{position:fixed;z-index:80;left:0;right:0;bottom:0;display:flex;gap:16rpx;padding:16rpx 32rpx;padding-bottom:calc(16rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,.96);border-top:1rpx solid #EEF0F3}.action-bar__btn{flex:1;height:88rpx;border-radius:44rpx;font-size:28rpx;font-weight:600;text-align:center;line-height:88rpx}.action-bar__btn--primary{background:#FF6B35;color:#fff}.action-bar__btn--primary:active{opacity:.85}.action-bar__btn--secondary{background:#FFF1EA;color:#FF6B35}.action-bar__btn--secondary:active{opacity:.85}.action-bar__icon{margin-right:6rpx;font-size:30rpx}
.summary-edit{display:inline-flex;align-items:center;margin-top:16rpx;color:#FF6B35;font-size:23rpx;font-weight:600}.summary-edit__icon{margin-right:8rpx;font-size:28rpx;line-height:1}.summary-edit:active{opacity:.65}
