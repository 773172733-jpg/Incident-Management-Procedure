@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.home-page{padding-top:env(safe-area-inset-top)}.home-header{padding-top:36rpx}.stats{display:flex;gap:20rpx;padding:12rpx 32rpx 34rpx}.stat{position:relative;flex:1;min-width:0;height:154rpx;padding:22rpx;box-sizing:border-box;border-radius:28rpx;background:#fff;box-shadow:var(--shadow-card);overflow:hidden}.stat--create{display:flex;flex-direction:column;align-items:center;justify-content:center;background:#FFF8F4;transition:transform .16s ease}.stat--create-pressed{transform:scale(.95)}.stat-icon{display:flex;align-items:center;justify-content:center;width:64rpx;height:64rpx;border-radius:50%;background:#FF6B35;color:#fff;font-size:42rpx;line-height:64rpx;text-align:center;transition:transform .16s ease}.stat--create-pressed .stat-icon{transform:rotate(90deg)}.stat-label,.stat-name{font-size:23rpx;color:#59606A}.stat-label{margin-top:10rpx;color:#1F2329;font-weight:600}.stat-number{display:block;margin-top:12rpx;font-size:48rpx;font-weight:700;color:#1F2329}.stat-number--info{color:#4E8DF5}.stat-mark{position:absolute;right:18rpx;bottom:18rpx;width:22rpx;height:22rpx;border-radius:50%;border:5rpx solid}.stat-mark--info{color:#4E8DF5}.stat-mark--success{color:#22B573}.filters{box-sizing:border-box;width:100%;height:76rpx;padding:0 32rpx;white-space:nowrap}.filter{display:inline-flex;align-items:center;height:58rpx;padding:0 28rpx;margin-right:14rpx;border-radius:999rpx;background:#fff;color:#8A9099;font-size:25rpx}.filter.on{background:#FFF1EA;color:#FF6B35;font-weight:600}.project-list{padding:0 32rpx 126rpx}.project-card{padding:28rpx;margin-bottom:24rpx;border-radius:32rpx;background:#fff;box-shadow:var(--shadow-card);transition:background .2s ease}.project-head{display:flex;align-items:center}.project-icon{display:flex;align-items:center;justify-content:center;width:84rpx;height:84rpx;border-radius:24rpx;font-size:32rpx;font-weight:700;line-height:84rpx;text-align:center;flex-shrink:0}.project-main{flex:1;min-width:0;margin-left:22rpx}.project-title-row{display:flex;align-items:center;justify-content:space-between}.project-title{max-width:390rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1F2329;font-size:31rpx;font-weight:600}.status{padding:6rpx 14rpx;border-radius:999rpx;background:#FFF1EA;color:#FF6B35;font-size:21rpx;flex-shrink:0}.status--completed{background:#EBF8F1;color:#22B573}.status--archived{background:#F1F2F4;color:#8A9099}.project-time{display:block;margin-top:10rpx;color:#8A9099;font-size:23rpx}
.expand-btn{display:flex;align-items:center;justify-content:center;width:64rpx;height:64rpx;margin-left:10rpx;border-radius:50%;flex-shrink:0}.expand-btn--hover{background:#F3F4F6}.expand-arrow{width:16rpx;height:16rpx;border-right:3rpx solid #B8BEC7;border-bottom:3rpx solid #B8BEC7;transform:rotate(45deg) translate(-2rpx,-2rpx);transition:transform .2s ease}.expand-arrow--open{transform:rotate(225deg) translate(-2rpx,-2rpx)}
.progress-row{display:flex;align-items:center;margin-top:26rpx}.progress-track{flex:1;height:12rpx;border-radius:999rpx;background:#F3F4F6;overflow:hidden}.progress-fill{height:100%;border-radius:999rpx;transition:width .3s ease}.progress-fill--min{min-width:14rpx}.progress-value{width:78rpx;margin-left:18rpx;text-align:right;color:#FF6B35;font-size:24rpx;font-weight:600}.project-foot{display:flex;justify-content:space-between;margin-top:18rpx;color:#8A9099;font-size:22rpx}
.project-card--done{background:#F4F5F7}.project-card--done .project-title{color:#6B7280}.project-card--done .project-time,.project-card--done .project-foot{color:#9AA0A8}.project-card--done .project-icon{filter:saturate(.4);opacity:.7}.project-card--done .progress-value{color:#8A9099}.project-card--done .progress-track{background:#EBECEF}
.task-preview{max-height:0;opacity:0;overflow:hidden;margin-top:0;transition:max-height .22s ease,opacity .22s ease,margin-top .22s ease}.task-preview--open{max-height:820rpx;opacity:1;margin-top:20rpx}.task-preview__inner{border-top:1rpx solid #EEF0F3;padding-top:2rpx}.preview-state{display:block;padding:22rpx 0 8rpx;color:#8A9099;text-align:center;font-size:22rpx}.preview-state--error{color:#F04A4A}.preview-task{display:flex;align-items:center;min-height:84rpx;border-bottom:1rpx solid #EEF0F3}.preview-task:last-of-type{border-bottom:0}.preview-task__main{flex:1;min-width:0}.preview-task__title,.preview-task__meta{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.preview-task__title{color:#1F2329;font-size:25rpx;font-weight:600}.preview-task__meta{margin-top:6rpx;color:#8A9099;font-size:20rpx}.preview-task__status{margin-left:16rpx;color:#59606A;font-size:20rpx;flex-shrink:0}.preview-task--done{opacity:.55}.preview-task--done .preview-task__title{text-decoration:line-through}.preview-more{display:block;padding:20rpx 0 6rpx;color:#FF6B35;text-align:center;font-size:23rpx;font-weight:600}
