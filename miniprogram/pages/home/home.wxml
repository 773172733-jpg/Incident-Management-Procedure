<view class="page home-page"><view class="page-header home-header"><view class="page-header__title">我的事件</view><view class="page-header__subtitle">专注目标，让每件事都有进度</view></view><view class="stats"><view class="stat stat--create" bindtap="create"><view class="stat-icon">＋</view><text class="stat-label">新建事件</text></view><view class="stat"><text class="stat-name">进行中</text><text class="stat-number stat-number--info">{{stats.active}}</text><view class="stat-mark stat-mark--info"></view></view><view class="stat"><text class="stat-name">已结束</text><text class="stat-number">{{stats.completed}}</text><view class="stat-mark stat-mark--success"></view></view></view><scroll-view class="filters" scroll-x enhanced show-scrollbar="{{false}}"><view wx:for="{{filters}}" wx:key="key" class="filter {{filter===item.key?'on':''}}" data-key="{{item.key}}" bindtap="chooseFilter">{{item.label}}</view></scroll-view><section-title title="{{filter==='completed'?'已结束的事件':'事件列表'}}" action="新建" bind:action="create"></section-title><loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><empty-state wx:elif="{{!visibleItems.length}}" title="{{items.length?'这个筛选下暂无事件':'还没有事件'}}" description="{{items.length?'换一个筛选条件看看':'把一件想做的事拆开，它就会开始变得清晰。'}}" action-text="创建第一个事件" bind:action="create"></empty-state><view wx:else class="project-list"><view wx:for="{{visibleItems}}" wx:key="_id" class="project-card" data-id="{{item._id}}" bindtap="detail"><view class="project-head"><view class="project-icon" style="color:{{item.themeColor||'#FF6B35'}};background:{{item.themeColor||'#FF6B35'}}1A">{{item.iconText}}</view><view class="project-main"><view class="project-title-row"><text class="project-title">{{item.title}}</text><text class="status status--{{item.status}}">{{item.statusText}}</text></view><text class="project-time">{{item.timeText}}</text></view></view><view class="progress-row"><view class="progress-track"><view class="progress-fill" style="width:{{item.progressValue}}%;background:{{item.themeColor||'#FF6B35'}}"></view></view><text class="progress-value">{{item.progressValue}}%</text></view><view class="project-foot"><text>已完成 {{item.countText}}</text><text>{{item.recentText}}</text></view></view></view><button class="float-add" bindtap="create"><text class="float-add__plus">＋</text>新建事件</button></view>
