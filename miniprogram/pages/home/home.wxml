<view class="page">
  <view class="page-header">
    <view class="page-header__title">我的事件</view>
    <view class="page-header__subtitle">专注目标，让每件事都有进度</view>
  </view>
  <scroll-view class="filters" scroll-x>
    <view wx:for="{{filters}}" wx:key="key" class="filter {{filter===item.key?'on':''}}" data-key="{{item.key}}" bindtap="chooseFilter">{{item.label}}</view>
  </scroll-view>
  <view wx:if="{{loading}}" class="empty-state">
    <text class="empty-state__text">正在加载...</text>
  </view>
  <view wx:elif="{{error}}" class="empty-state">
    <text class="empty-state__text">{{error}}</text>
    <button class="btn-secondary empty-state__btn" bindtap="retry">重试</button>
  </view>
  <view wx:elif="{{!items.length}}" class="empty-state">
    <text class="empty-state__text">还没有事件。把一件想做的事拆开，它就会开始变得清晰。</text>
    <button class="btn-primary empty-state__btn" bindtap="create">创建第一个事件</button>
  </view>
  <view wx:else>
    <view wx:for="{{items}}" wx:key="_id" class="card project" data-id="{{item._id}}" bindtap="detail">
      <view class="project-top">
        <text class="project-title">{{item.title}}</text>
        <text class="tag">{{item.status==='active'?'进行中':item.status==='completed'?'已结束':item.status}}</text>
      </view>
      <text class="project-time">{{item.timeText}}</text>
      <view class="bar">
        <view class="bar-in" style="width:{{item.progressText}}"></view>
      </view>
      <text class="project-time">{{item.progressText}} - 已完成{{item.countText}}</text>
    </view>
  </view>
  <button class="float-add" bindtap="create">新建事件</button>
</view>
