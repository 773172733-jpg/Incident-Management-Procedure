<view class="page group-page"><view class="custom-nav" style="{{navStyle}}"><view class="back" bindtap="back"><view class="back-arrow"></view></view><text class="nav-title">管理分组</text><view class="nav-space"></view></view><view class="intro-row"><text>分组用于整理备忘录中的分支任务，不会改变任务本身。</text><text wx:if="{{groups.length}}" class="sort-toggle" bindtap="toggleSorting">{{sortingMode?'完成':'调整顺序'}}</text></view><loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="分组加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><empty-state wx:elif="{{!groups.length}}" title="还没有分组" description="创建分组，让任务更容易整理" action-text="创建第一个分组" bind:action="createGroup"></empty-state><view wx:else class="group-list"><view wx:for="{{groups}}" wx:key="_id" class="group-card"><view class="group-icon" style="background:{{item.color}}"><view class="icon-mark icon-mark--{{item.icon}}"></view></view><view class="group-copy"><text class="group-name">{{item.name}}</text><text class="group-count">{{item.taskCount}}个分支任务</text></view><view wx:if="{{sortingMode}}" class="sort-actions"><button disabled="{{index===0||operating}}" data-index="{{index}}" data-direction="-1" bindtap="move">上移</button><button disabled="{{index===groups.length-1||operating}}" data-index="{{index}}" data-direction="1" bindtap="move">下移</button></view><button wx:else class="more" data-item="{{item}}" bindtap="showMenu"><view class="dot"></view><view class="dot"></view><view class="dot"></view></button></view></view><bottom-action-bar text="＋ 新建分组" loading="{{editing}}" disabled="{{editing}}" bind:action="createGroup"></bottom-action-bar></view>
