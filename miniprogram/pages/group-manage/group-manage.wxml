<view class="page group-page"><view class="page-header"><text class="page-header__title">管理分组</text><text class="page-header__subtitle">组织任务结构，调整顺序后自动保存</text></view><loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><empty-state wx:elif="{{!groups.length}}" title="暂无分组" description="创建分组后，可以让任务结构更清晰" action-text="新建分组" bind:action="createGroup"></empty-state><view wx:else class="group-list"><view wx:for="{{groups}}" wx:key="_id" class="group-card"><view class="group-main" data-item="{{item}}" bindtap="editGroup"><view class="group-icon" style="background:{{item.color}}"><view class="group-icon__mark"></view></view><view class="group-info"><text class="group-name">{{item.name}}</text><text class="group-meta">{{item.icon||'folder'}} · 点击编辑名称、颜色和图标</text></view><text class="edit-text">编辑</text></view><view class="group-actions"><button disabled="{{index===0||operating}}" data-index="{{index}}" data-direction="-1" bindtap="move">上移</button><button disabled="{{index===groups.length-1||operating}}" data-index="{{index}}" data-direction="1" bindtap="move">下移</button><button class="danger" data-item="{{item}}" bindtap="deleteGroup">删除</button></view></view></view><bottom-action-bar text="新建分组" bind:action="createGroup"></bottom-action-bar></view>
