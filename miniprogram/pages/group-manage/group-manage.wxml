<view class="page"><view class="page-header"><view class="page-header__title">管理分组</view><view class="page-header__subtitle">调整顺序后会自动保存</view></view><view wx:if="{{loading}}" class="empty-state"><text class="empty-state__text">正在加载…</text></view><view wx:elif="{{!groups.length}}" class="empty-state"><text class="empty-state__text">暂无分组，可以先创建一个</text></view><view wx:for="{{groups}}" wx:key="_id" class="card group"><view class="group-main" data-item="{{item}}" bindtap="editGroup"><view class="group-icon" style="background:{{item.color}}"></view><view><view class="group-name">{{item.name}}</view><view class="group-meta">{{item.icon || 'folder'}} · 点击编辑</view></view></view><view class="actions"><button size="mini" disabled="{{index===0||operating}}" data-index="{{index}}" data-direction="-1" bindtap="move">上移</button><button size="mini" disabled="{{index===groups.length-1||operating}}" data-index="{{index}}" data-direction="1" bindtap="move">下移</button><button size="mini" class="danger" data-item="{{item}}" bindtap="deleteGroup">删除</button></view></view><button class="btn-primary add" bindtap="createGroup">新建分组</button></view>
