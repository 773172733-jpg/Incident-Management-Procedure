@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.group-page{padding-bottom:calc(150rpx + env(safe-area-inset-bottom))}.group-list{padding:0 32rpx}.group-card{margin-bottom:22rpx;padding:26rpx;border-radius:28rpx;background:#fff;box-shadow:var(--shadow-card)}.group-main{display:flex;align-items:center}.group-icon{position:relative;width:74rpx;height:74rpx;border-radius:22rpx;opacity:.9}.group-icon__mark{position:absolute;left:20rpx;right:20rpx;top:25rpx;height:5rpx;border-radius:8rpx;background:#fff;box-shadow:0 12rpx 0 #fff}.group-info{flex:1;min-width:0;margin-left:20rpx}.group-name,.group-meta{display:block}.group-name{color:#1F2329;font-size:29rpx;font-weight:600}.group-meta{margin-top:8rpx;color:#8A9099;font-size:21rpx}.edit-text{color:#FF6B35;font-size:23rpx}.group-actions{display:flex;justify-content:flex-end;margin-top:22rpx;padding-top:20rpx;border-top:1rpx solid #EEF0F3}.group-actions button{height:54rpx;margin:0 0 0 12rpx;padding:0 20rpx;border-radius:16rpx;background:#F7F8FA;color:#59606A;font-size:22rpx;line-height:54rpx}.group-actions button[disabled]{opacity:.35}.group-actions .danger{background:#FFF0F0;color:#F04A4A}
