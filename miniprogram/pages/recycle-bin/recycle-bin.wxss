@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.recycle-header{display:flex;align-items:flex-start;justify-content:space-between}.recycle-header__copy{flex:1;min-width:0}.clear-trash{height:58rpx;margin:6rpx 0 0 20rpx;padding:0 22rpx;border-radius:17rpx;background:#FFF0F0;color:#F04A4A;font-size:22rpx;line-height:58rpx}.clear-trash[disabled]{opacity:.4}.tabs{display:flex;margin:0 32rpx 18rpx;padding:8rpx;border-radius:22rpx;background:#EEF0F3}.tab{flex:1;height:62rpx;border-radius:17rpx;color:#8A9099;text-align:center;font-size:24rpx;line-height:62rpx}.tab text{margin-left:5rpx;font-size:19rpx}.tab.selected{background:#fff;color:#FF6B35;font-weight:600;box-shadow:0 4rpx 12rpx rgba(31,35,41,.05)}.task-card{margin:0 32rpx 22rpx;padding:27rpx;border-radius:30rpx;background:#fff;box-shadow:var(--shadow-card)}.task-head{display:flex;align-items:center}.task-title{flex:1;min-width:0;margin-left:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1F2329;font-size:28rpx;font-weight:600}.task-meta,.warning{display:block;margin-top:10rpx;color:#8A9099;font-size:21rpx}.warning{color:#F04A4A}.task-actions{display:flex;justify-content:flex-end;margin-top:20rpx;padding-top:18rpx;border-top:1rpx solid #EEF0F3}.restore-task{height:56rpx;margin:0;padding:0 22rpx;border-radius:17rpx;background:#FFF1EA;color:#FF6B35;font-size:22rpx;line-height:56rpx}.restore-task[disabled]{opacity:.4}
