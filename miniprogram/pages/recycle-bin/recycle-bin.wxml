<view class="page"><view class="page-header"><text class="page-header__title">回收站</text><view class="page-header__subtitle">恢复任务前，所属事件必须处于正常状态</view></view><view wx:if="{{loading}}" class="empty-state"><text class="empty-state__text">正在加载…</text></view><view wx:elif="{{error}}" class="empty-state"><text class="empty-state__text">{{error}}</text><button class="btn-secondary empty-state__btn" bindtap="retry">重试</button></view><block wx:else><view wx:if="{{!projects.length&&!tasks.length}}" class="empty-state"><text class="empty-state__text">回收站为空</text></view><view wx:if="{{projects.length}}" class="section-title">已删除事件</view><view wx:for="{{projects}}" wx:key="_id" class="card recycle-item"><view><text class="item-title">{{item.title}}</text><text class="item-meta">删除于 {{item.deletedText}}</text></view><button class="restore" size="mini" data-id="{{item._id}}" bindtap="restoreProject">恢复</button></view><view wx:if="{{tasks.length}}" class="section-title">已删除任务</view><view wx:for="{{tasks}}" wx:key="_id" class="card recycle-item"><view><text class="item-title">{{item.title}}</text><text class="item-meta">所属事件：{{item.projectTitle}}</text><text class="item-meta">删除于 {{item.deletedText}}</text><text wx:if="{{item.parentProjectDeleted}}" class="warning">请先恢复所属事件</text></view><button class="restore" size="mini" disabled="{{item.parentProjectDeleted}}" data-id="{{item._id}}" bindtap="restoreTask">恢复</button></view></block></view>
