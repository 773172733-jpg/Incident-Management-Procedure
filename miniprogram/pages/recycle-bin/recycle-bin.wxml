<view class="page"><view class="page-header"><text class="page-header__title">回收站</text><view class="page-header__subtitle">恢复任务前，所属事件必须处于正常状态</view></view><loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><empty-state wx:elif="{{!projects.length&&!tasks.length}}" title="回收站为空" description="删除的事件与任务会暂时保存在这里"></empty-state><block wx:else><section-title wx:if="{{projects.length}}" title="已删除事件"></section-title><view wx:for="{{projects}}" wx:key="_id" class="card recycle-item"><view class="item-icon item-icon--project"><view class="item-icon__line"></view></view><view class="item-copy"><text class="item-title">{{item.title}}</text><text class="item-meta">删除于 {{item.deletedText}}</text></view><button class="restore" data-id="{{item._id}}" bindtap="restoreProject">恢复</button></view><section-title wx:if="{{tasks.length}}" title="已删除任务"></section-title><view wx:for="{{tasks}}" wx:key="_id" class="card recycle-item"><view class="item-icon item-icon--task"><view class="item-icon__line"></view></view><view class="item-copy"><text class="item-title">{{item.title}}</text><text class="item-meta">所属事件：{{item.projectTitle}}</text><text class="item-meta">删除于 {{item.deletedText}}</text><text wx:if="{{item.parentProjectDeleted}}" class="warning">请先恢复所属事件</text></view><button class="restore" disabled="{{item.parentProjectDeleted}}" data-id="{{item._id}}" bindtap="restoreTask">恢复</button></view></block></view>
