<view class="page recycle-page"><view class="page-header"><text class="page-header__title">回收站</text><view class="page-header__subtitle">删除的内容会保留在这里，恢复任务前需先恢复所属事件</view></view><view class="tabs"><view class="tab {{tab==='all'?'selected':''}}" data-tab="all" bindtap="chooseTab">全部 <text>{{projects.length+tasks.length}}</text></view><view class="tab {{tab==='project'?'selected':''}}" data-tab="project" bindtap="chooseTab">项目 <text>{{projects.length}}</text></view><view class="tab {{tab==='task'?'selected':''}}" data-tab="task" bindtap="chooseTab">任务 <text>{{tasks.length}}</text></view></view><loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="回收站加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><empty-state wx:elif="{{!projects.length&&!tasks.length}}" title="回收站为空" description="删除的事件和任务会暂时保存在这里"></empty-state><empty-state wx:elif="{{!visibleProjects.length&&!visibleTasks.length}}" title="{{tab==='project'?'暂无已删除项目':'暂无已删除任务'}}" description="切换分类可以查看其他已删除内容"></empty-state><block wx:else><section-title wx:if="{{visibleProjects.length}}" title="已删除项目"></section-title><list-project-card wx:for="{{visibleProjects}}" wx:key="_id" item="{{item}}" primary-text="恢复项目" bind:primary="restoreProject"></list-project-card><section-title wx:if="{{visibleTasks.length}}" title="已删除任务"></section-title><view wx:for="{{visibleTasks}}" wx:key="_id" class="task-card"><view class="task-head"><priority-tag priority="{{item.priority}}" label="{{item.priorityText}}"></priority-tag><text class="task-title">{{item.title}}</text></view><text class="task-meta">所属事件：{{item.projectTitle}}</text><text class="task-meta">删除于 {{item.deletedText}}</text><text wx:if="{{item.parentProjectDeleted}}" class="warning">请先恢复所属事件</text><view class="task-actions"><button class="restore-task" disabled="{{item.parentProjectDeleted||operatingId===item._id}}" loading="{{operatingId===item._id}}" data-item="{{item}}" bindtap="restoreTask">恢复任务</button></view></view></block></view>
