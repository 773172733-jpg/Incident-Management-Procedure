<view class="page recycle-page">
  <view class="page-header recycle-header">
    <view class="recycle-header__copy">
      <text class="page-header__title">回收站</text>
      <view class="page-header__subtitle">共{{projects.length+tasks.length}}项，恢复分支任务前需先恢复所属备忘录</view>
    </view>
    <button wx:if="{{projects.length||tasks.length}}" class="clear-trash" loading="{{clearing}}" disabled="{{clearing||operatingId}}" bindtap="clearTrash">清空回收站</button>
  </view>
  <view class="capacity-note">回收站最多保留100条备忘录，超出后将自动永久删除最早移入回收站的内容。</view>
  <view class="tabs">
    <view class="tab {{tab==='all'?'selected':''}}" data-tab="all" bindtap="chooseTab">全部 <text>{{projects.length+tasks.length}}</text></view>
    <view class="tab {{tab==='project'?'selected':''}}" data-tab="project" bindtap="chooseTab">备忘录 <text>{{projects.length}}</text></view>
    <view class="tab {{tab==='task'?'selected':''}}" data-tab="task" bindtap="chooseTab">分支任务 <text>{{tasks.length}}</text></view>
  </view>
  <loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton>
  <empty-state wx:elif="{{error}}" type="error" title="回收站加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state>
  <empty-state wx:elif="{{!projects.length&&!tasks.length}}" title="回收站是空的" description="删除的备忘录和分支任务会暂时保存在这里"></empty-state>
  <empty-state wx:elif="{{!visibleProjects.length&&!visibleTasks.length}}" title="{{tab==='project'?'暂无已删除备忘录':'暂无已删除分支任务'}}" description="切换分类可以查看其他已删除内容"></empty-state>
  <block wx:else>
    <section-title wx:if="{{visibleProjects.length}}" title="备忘录（{{visibleProjects.length}}）"></section-title>
    <list-project-card wx:for="{{visibleProjects}}" wx:key="_id" item="{{item}}" primary-text="恢复备忘录" secondary-text="永久删除" bind:primary="restoreProject" bind:secondary="purgeProject"></list-project-card>
    <section-title wx:if="{{visibleTasks.length}}" title="分支任务（{{visibleTasks.length}}）"></section-title>
    <view wx:for="{{visibleTasks}}" wx:key="_id" class="task-card">
      <view class="task-head"><priority-tag priority="{{item.priority}}" label="{{item.priorityText}}"></priority-tag><text class="task-title">{{item.title}}</text></view>
      <text class="task-meta">所属备忘录：{{item.projectTitle}}</text>
      <text class="task-meta">删除于 {{item.deletedText}}</text>
      <text wx:if="{{item.parentProjectDeleted}}" class="warning">请先恢复所属备忘录</text>
      <view class="task-actions"><button class="restore-task" disabled="{{item.parentProjectDeleted||operatingId===item._id||clearing}}" loading="{{operatingId===item._id}}" data-item="{{item}}" bindtap="restoreTask">恢复分支任务</button></view>
    </view>
  </block>
</view>
