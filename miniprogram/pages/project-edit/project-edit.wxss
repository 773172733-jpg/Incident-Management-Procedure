@import '../../styles/variables.wxss';@import '../../styles/common.wxss';.project-form{padding-bottom:calc(150rpx + env(safe-area-inset-bottom))}.form-card{margin:0 32rpx;padding:0 28rpx;border-radius:28rpx;background:#fff;box-shadow:var(--shadow-card)}.field,.date-row{padding:28rpx 0;border-bottom:1rpx solid #EEF0F3}.field:last-child,.date-row:last-child{border-bottom:0}.label{display:block;margin-bottom:14rpx;color:#59606A;font-size:24rpx;font-weight:500}.input{height:64rpx;color:#1F2329;font-size:29rpx}.textarea{width:100%;min-height:150rpx;color:#1F2329;font-size:27rpx}.counter{display:block;text-align:right;color:#B8BEC7;font-size:20rpx}.modes{padding:16rpx 0}.mode{position:relative;padding:24rpx 24rpx 24rpx 64rpx;margin:12rpx 0;border:2rpx solid #EEF0F3;border-radius:22rpx}.mode.on{border-color:#FFB18E;background:#FFF8F4}.mode-mark{position:absolute;left:22rpx;top:30rpx;width:24rpx;height:24rpx;border:3rpx solid #D9DDE2;border-radius:50%}.mode.on .mode-mark{border:8rpx solid #FF6B35;box-sizing:border-box}.mode-name,.mode-desc{display:block}.mode-name{color:#1F2329;font-size:27rpx;font-weight:600}.mode-desc{margin-top:6rpx;color:#8A9099;font-size:21rpx}.date-value{display:flex;align-items:center;justify-content:space-between;color:#1F2329;font-size:27rpx}.chevron{width:14rpx;height:14rpx;border-top:3rpx solid #B8BEC7;border-right:3rpx solid #B8BEC7;transform:rotate(45deg)}
.icon-grid{display:flex;flex-wrap:wrap;gap:12rpx;padding:6rpx 0}.icon-option{display:flex;align-items:center;justify-content:center;width:72rpx;height:72rpx;font-size:36rpx;border-radius:18rpx;background:#F5F6F7;transition:all .15s}.icon-option.selected{background:#FFF1EA;transform:scale(1.15)}.icon-preview{padding-top:12rpx;text-align:center;font-size:23rpx;color:#8A9099}.icon-preview .icon-preview-value{font-size:44rpx}.icon-preview--hint{font-size:20rpx;color:#B8BEC7}