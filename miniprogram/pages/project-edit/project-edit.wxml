<view class="page project-form"><view class="page-header"><view class="page-header__title">{{id?'编辑大事件':'新建大事件'}}</view><view class="page-header__subtitle">明确目标，再一步步推进</view></view><loading-skeleton wx:if="{{loading}}" rows="3"></loading-skeleton><empty-state wx:elif="{{error}}" type="error" title="加载失败" description="{{error}}" action-text="重新加载" bind:action="retry"></empty-state><block wx:else><section-title title="大事件信息"></section-title><view class="form-card"><view class="field"><text class="label">大事件名称</text><input class="input" value="{{title}}" maxlength="40" placeholder="例如：二级建造师考试" data-key="title" bindinput="input"/></view><view class="field"><text class="label">大事件说明</text><textarea class="textarea" value="{{description}}" maxlength="1000" placeholder="补充大事件背景或目标（可选）" data-key="description" bindinput="input"/><text class="counter">{{description.length}}/1000</text></view></view><section-title title="大事件图标"></section-title><view class="form-card"><view class="icon-grid"><view wx:for="{{emojis}}" wx:key="*this" class="icon-option {{iconValue===item?'selected':''}}" data-value="{{item}}" bindtap="chooseIcon">{{item}}</view></view><view wx:if="{{iconValue}}" class="icon-preview"><text class="icon-preview-value">{{iconValue}}</text></view><view wx:else class="icon-preview icon-preview--hint"><text>选择图标后，将代替大事件名称首字显示</text></view></view><section-title title="主题色"></section-title><view class="form-card"><view class="color-grid"><view wx:for="{{themeColors}}" wx:key="*this" class="color-option {{themeColor===item?'selected':''}}" style="background:{{item}}" data-value="{{item}}" bindtap="chooseThemeColor"><view wx:if="{{themeColor===item}}" class="color-check"></view></view></view></view><section-title title="时间安排"></section-title><view class="form-card"><view class="modes"><view class="mode {{timeMode==='none'?'on':''}}" data-mode="none" bindtap="mode"><view class="mode-mark"></view><text class="mode-name">无时间</text><text class="mode-desc">适合暂未确定日期的大事件</text></view><view class="mode {{timeMode==='range'?'on':''}}" data-mode="range" bindtap="mode"><view class="mode-mark"></view><text class="mode-name">起止区间</text><text class="mode-desc">明确开始和结束日期</text></view><view class="mode {{timeMode==='ongoing'?'on':''}}" data-mode="ongoing" bindtap="mode"><view class="mode-mark"></view><text class="mode-name">持续进行</text><text class="mode-desc">长期推进，不设置结束日期</text></view></view><view wx:if="{{timeMode!=='none'}}" class="date-row"><text class="label">开始日期</text><picker mode="date" value="{{startAt}}" data-key="startAt" bindchange="input"><view class="date-value">{{startAt||'请选择开始日期'}}<view class="chevron"></view></view></picker></view><view wx:if="{{timeMode==='range'}}" class="date-row"><text class="label">结束日期</text><picker mode="date" value="{{endAt}}" start="{{startAt}}" data-key="endAt" bindchange="input"><view class="date-value">{{endAt||'请选择结束日期'}}<view class="chevron"></view></view></picker></view></view><bottom-action-bar text="保存" loading="{{saving}}" disabled="{{saving}}" bind:action="save"></bottom-action-bar></block></view>
