.tabbar{position:fixed;z-index:100;left:0;right:0;bottom:0;display:flex;flex-wrap:wrap;background:rgba(255,255,255,.98);border-top:1rpx solid #EEF0F3;box-shadow:0 -8rpx 24rpx rgba(31,35,41,.04)}.tab{width:25%;height:100rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#A7ADB5;font-size:21rpx}.tab--active{color:#FF6B35}.icon{position:relative;width:38rpx;height:38rpx;margin-bottom:5rpx}.icon-inner,.icon::before,.icon::after{position:absolute;box-sizing:border-box;border:4rpx solid currentColor}.icon--home::before{content:'';width:27rpx;height:27rpx;left:6rpx;top:8rpx;transform:rotate(45deg);border-radius:5rpx}.icon--home::after{content:'';width:18rpx;height:22rpx;left:10rpx;top:16rpx;background:#fff;border-top:0}.icon--calendar::before{content:'';left:2rpx;right:2rpx;top:5rpx;bottom:1rpx;border-radius:6rpx}.icon--calendar::after{content:'';left:7rpx;right:7rpx;top:13rpx;border-width:2rpx 0 0}.icon--activity::before{content:'';left:2rpx;right:2rpx;top:17rpx;height:4rpx;border:0;background:currentColor;transform:rotate(-12deg)}.icon--activity::after{content:'';width:10rpx;height:10rpx;right:0;top:7rpx;border-radius:50%;background:#fff}.icon--profile::before{content:'';width:16rpx;height:16rpx;left:11rpx;top:1rpx;border-radius:50%}.icon--profile::after{content:'';width:32rpx;height:18rpx;left:3rpx;bottom:0;border-radius:18rpx 18rpx 6rpx 6rpx}.safe{width:100%;height:env(safe-area-inset-bottom)}
