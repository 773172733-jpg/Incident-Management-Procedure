.state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:64rpx 40rpx;text-align:center}.state-icon{width:92rpx;height:92rpx;border-radius:28rpx;background:#FFF1EA;position:relative;margin-bottom:24rpx}.state-icon__line{position:absolute;left:24rpx;right:24rpx;top:44rpx;height:6rpx;border-radius:9rpx;background:#FF6B35}.state-icon__line::before,.state-icon__line::after{content:'';position:absolute;width:6rpx;height:30rpx;top:-12rpx;border-radius:9rpx;background:#FF6B35}.state-icon__line::before{left:10rpx}.state-icon__line::after{right:10rpx}.state-icon--error{background:#FFF0F0}.state-icon--error .state-icon__line{background:#F04A4A}.state-title{font-size:30rpx;font-weight:600;color:#1F2329}.state-description{max-width:560rpx;margin-top:12rpx;color:#8A9099;font-size:25rpx;line-height:1.65}.state-action{margin-top:28rpx;padding:0 36rpx;height:76rpx;line-height:76rpx;border-radius:24rpx;background:#FF6B35;color:#fff;font-size:27rpx}
