.state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:64rpx 40rpx;text-align:center}.state-icon{position:relative;width:92rpx;height:92rpx;margin-bottom:24rpx;box-sizing:border-box;border:3rpx solid #CAD4DF;border-radius:28rpx;background:#F3F6F9}.state-icon::before{content:'';position:absolute;left:27rpx;top:26rpx;width:34rpx;height:20rpx;border-left:6rpx solid #7C8EA3;border-bottom:6rpx solid #7C8EA3;border-radius:3rpx;transform:rotate(-45deg)}.state-icon--error{border-color:#F2C8C8;background:#FFF4F4}.state-icon--error::before,.state-icon--error::after{content:'';position:absolute;left:43rpx;top:23rpx;width:6rpx;height:44rpx;border:0;border-radius:6rpx;background:#D96B6B;transform:rotate(45deg)}.state-icon--error::after{transform:rotate(-45deg)}.state-title{font-size:30rpx;font-weight:600;color:#1F2329}.state-description{max-width:560rpx;margin-top:12rpx;color:#8A9099;font-size:25rpx;line-height:1.65}.state-action{margin-top:28rpx;padding:0 36rpx;height:76rpx;line-height:76rpx;border-radius:24rpx;background:#FF6B35;color:#fff;font-size:27rpx}
