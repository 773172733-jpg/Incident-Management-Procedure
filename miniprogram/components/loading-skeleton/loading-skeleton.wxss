.skeleton{padding:12rpx 32rpx}.skeleton-card{display:flex;padding:32rpx;margin-bottom:24rpx;border-radius:32rpx;background:#fff}.skeleton-icon{width:88rpx;height:88rpx;border-radius:24rpx}.skeleton-body{flex:1;margin-left:24rpx}.skeleton-title{width:54%;height:28rpx;border-radius:8rpx}.skeleton-line{height:20rpx;margin-top:22rpx;border-radius:8rpx}.skeleton-line--short{width:70%}.shimmer{background:linear-gradient(90deg,#F1F2F4 25%,#FAFAFB 50%,#F1F2F4 75%);background-size:200% 100%;animation:shine 1.4s infinite}@keyframes shine{from{background-position:200% 0}to{background-position:-200% 0}}
