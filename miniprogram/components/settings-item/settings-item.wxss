.item{display:flex;align-items:center;min-height:104rpx;padding:18rpx 0;border-bottom:1rpx solid #EEF0F3;box-sizing:border-box}.item:last-child{border-bottom:0}.icon{position:relative;width:68rpx;height:68rpx;border-radius:21rpx;background:#FFF1EA;color:#FF6B35;flex-shrink:0}.icon--archive{background:#F1F2F4;color:#8A9099}.icon--recycle{background:#FFF0F0;color:#F04A4A}.icon--notice,.icon--privacy{background:#EEF4FF;color:#4E8DF5}.icon--sink{background:#EBF8F1;color:#22B573}.icon--timezone{background:#FFF8DF;color:#A87300}.icon-mark{position:absolute;left:20rpx;right:20rpx;top:20rpx;bottom:20rpx;border:4rpx solid currentColor;border-radius:6rpx}.icon--sink .icon-mark{top:31rpx;bottom:auto;height:4rpx;border:0;background:currentColor;box-shadow:0 11rpx 0 currentColor}.copy{flex:1;min-width:0;margin-left:20rpx}.title,.description{display:block}.title{color:#1F2329;font-size:27rpx;font-weight:500}.description{margin-top:6rpx;color:#8A9099;font-size:21rpx}.value{max-width:180rpx;margin-left:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#8A9099;font-size:22rpx}.chevron{width:14rpx;height:14rpx;margin:0 8rpx;border-top:3rpx solid #B8BEC7;border-right:3rpx solid #B8BEC7;transform:rotate(45deg)}.switch{transform:scale(.82);transform-origin:right center}
