.item{position:relative;display:flex;align-items:center;min-height:104rpx;padding:18rpx 0;border-bottom:1rpx solid #EEF0F3;box-sizing:border-box}.item:last-child{border-bottom:0}.item--semantic{min-height:112rpx;padding:20rpx 4rpx;border-bottom:0;border-radius:14rpx}.item--semantic::after{content:'';position:absolute;left:84rpx;right:4rpx;bottom:0;height:1rpx;background:#EEF0F3}.item--semantic:last-child::after{display:none}.item--semantic:active{background:#FAF7F5}.icon{position:relative;width:68rpx;height:68rpx;border-radius:21rpx;background:#FFF1EA;color:#FF6B35;flex-shrink:0}.icon--archive{background:#F1F2F4;color:#8A9099}.icon--recycle{background:#FFF0F0;color:#F04A4A}.icon--notice,.icon--privacy{background:#EEF4FF;color:#4E8DF5}.icon--sink{background:#EBF8F1;color:#22B573}.icon--timezone{background:#FFF8DF;color:#A87300}.icon-mark{position:absolute;left:20rpx;right:20rpx;top:20rpx;bottom:20rpx;border:4rpx solid currentColor;border-radius:6rpx}.icon--sink .icon-mark{top:31rpx;bottom:auto;height:4rpx;border:0;background:currentColor;box-shadow:0 11rpx 0 currentColor}.copy{flex:1;min-width:0;margin-left:20rpx}.item--semantic .copy{margin-left:16rpx}.title,.description{display:block}.title{color:#1F2329;font-size:27rpx;font-weight:500}.description{margin-top:6rpx;color:#8A9099;font-size:21rpx;line-height:30rpx}.value{max-width:180rpx;margin-left:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#8A9099;font-size:22rpx}.chevron{width:13rpx;height:13rpx;margin:0 8rpx 0 14rpx;border-top:3rpx solid #B8BEC7;border-right:3rpx solid #B8BEC7;transform:rotate(45deg);flex-shrink:0}.switch{transform:scale(.82);transform-origin:right center;flex-shrink:0}
