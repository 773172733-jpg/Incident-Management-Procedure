.card{margin:0 32rpx 24rpx;padding:30rpx;border-radius:32rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(31,35,41,.05)}.top{display:flex;align-items:flex-end;justify-content:space-between}.label{color:#1F2329;font-size:25rpx;font-weight:600}.number{color:#FF6B35;font-size:56rpx;font-weight:700}.track{height:14rpx;margin-top:23rpx;border-radius:999rpx;background:#EEF0F3;overflow:hidden}.fill{height:100%;border-radius:999rpx;transition:width .2s ease}.meta{display:flex;justify-content:space-between;margin-top:17rpx;color:#8A9099;font-size:21rpx}
