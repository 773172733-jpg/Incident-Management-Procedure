.card{display:flex;align-items:flex-start;margin:0 32rpx 20rpx;padding:26rpx;border-radius:30rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(31,35,41,.05)}.main{flex:1;min-width:0}.title-row{display:flex;align-items:center}.title{margin-left:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1F2329;font-size:27rpx;font-weight:600}.project{display:block;margin-top:10rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#8A9099;font-size:21rpx}.meta-row{display:flex;align-items:center;margin-top:10rpx}.time,.status{margin-right:12rpx;color:#8A9099;font-size:20rpx}.time--overdue{color:#F04A4A}.status{padding:4rpx 10rpx;border-radius:999rpx;background:#F1F2F4}.status--completed{background:#EBF8F1;color:#22B573}.status--todo,.status--doing{background:#FFF1EA;color:#FF6B35}.status--closed_by_parent{color:#8A9099}.check{display:flex;flex:0 0 48rpx;align-items:center;justify-content:center;width:48rpx;min-width:48rpx;max-width:48rpx;height:48rpx;min-height:48rpx;max-height:48rpx;margin:0 0 0 15rpx;padding:0;box-sizing:border-box;border:3rpx solid #D9DDE2;border-radius:50%;background:#fff}.check--done{border-color:#FF6B35;background:#FF6B35}
.check--disabled{border-color:#D9DDE2;background:#F1F2F4}.mark{width:13rpx;height:7rpx;border-left:3rpx solid transparent;border-bottom:3rpx solid transparent;border-radius:2rpx;transform:rotate(-45deg)}.check--done .mark{border-color:#fff}.card--done{opacity:.62}.card--done .title{text-decoration:line-through;color:#8A9099}
