<view class="card {{item.isCompleted?'card--done':''}}"><view class="main" bindtap="open"><view class="title-row"><priority-tag priority="{{item.priority}}" label="{{item.priorityText}}"></priority-tag><text class="title">{{item.title}}</text></view><text class="project">所属大事件：{{item.projectTitle}}</text><view class="meta-row"><text class="time {{item.overdue?'time--overdue':''}}">{{item.timeText}}</text><text class="status status--{{item.status}}">{{item.statusText}}</text></view></view><view class="check {{item.isCompleted?'check--done':''}} {{item.status==='closed_by_parent'?'check--disabled':''}}" catchtap="toggle"><view class="mark"></view></view></view>
