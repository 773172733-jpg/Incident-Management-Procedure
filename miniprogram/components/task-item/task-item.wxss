:host{display:block;width:100%;visibility:visible;opacity:1}
.task{display:flex;align-items:flex-start;margin:0 32rpx 20rpx;padding:27rpx;border-radius:30rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(31,35,41,.05)}.task-item__main{flex:1;min-width:0}.task-item__title-row{display:flex;align-items:center}.task-item__title{margin-left:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1F2329;font-size:28rpx;font-weight:500}.task-item__note{display:block;margin-top:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#8A9099;font-size:22rpx}.task-item__time-row{display:flex;align-items:center;flex-wrap:wrap;margin-top:12rpx}.task-item__time,.task-item__completed,.task-item__closed{margin-right:14rpx;color:#8A9099;font-size:21rpx}.task-item__time--overdue{color:#F04A4A}.task-item__completed{color:#22B573}.task-item__closed{padding:4rpx 10rpx;border-radius:999rpx;background:#F1F2F4;color:#8A9099}.task--done{opacity:.62}.task--done .task-item__title{text-decoration:line-through;color:#8A9099}.task--closed{opacity:.78}.task-item__actions{display:flex;align-items:center;margin-left:16rpx}.task-item__check{display:flex;align-items:center;justify-content:center;width:58rpx;height:58rpx;margin:0;padding:0;border:3rpx solid #D9DDE2;border-radius:50%;background:#fff}.task-item__check--done{border-color:#FF6B35;background:#FF6B35}.task-item__check--disabled{border-color:#D9DDE2;background:#F1F2F4}.task-item__check-mark{width:18rpx;height:10rpx;border-left:4rpx solid transparent;border-bottom:4rpx solid transparent;transform:rotate(-45deg)}.check--done .task-item__check-mark{border-color:#fff}.task-item__more{display:flex;align-items:center;justify-content:center;width:54rpx;height:58rpx;margin:0 0 0 8rpx;padding:0;background:transparent}.task-item__dot{width:6rpx;height:6rpx;margin:0 3rpx;border-radius:50%;background:#8A9099}
