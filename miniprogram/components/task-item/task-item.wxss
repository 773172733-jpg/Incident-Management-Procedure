:host{display:block;width:100%;box-sizing:border-box}.task-item{display:flex;align-items:flex-start;width:auto;margin:0 32rpx 20rpx;padding:27rpx;box-sizing:border-box;border-radius:30rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(31,35,41,.05)}.task-item__main{flex:1 1 auto;width:0;min-width:0}.task-item__title-row{display:flex;align-items:center;min-width:0}.task-item__title{flex:1;min-width:0;margin-left:12rpx;overflow:hidden;color:#1f2329;font-size:28rpx;font-weight:500;line-height:40rpx;text-overflow:ellipsis;white-space:nowrap}.task-item__note{display:block;margin-top:12rpx;overflow:hidden;color:#8a9099;font-size:22rpx;line-height:32rpx;text-overflow:ellipsis;white-space:nowrap}.task-item__time-row{display:flex;align-items:center;flex-wrap:wrap;width:100%;margin-top:12rpx}.task-item__time{display:inline-block;width:auto;white-space:nowrap;margin-right:14rpx;color:#8a9099;font-size:21rpx}.task-item__time--overdue{color:#f04a4a}.task-item__completed{display:inline-block;white-space:nowrap;margin-right:14rpx;color:#22b573;font-size:21rpx}.task-item__closed{display:inline-block;white-space:nowrap;padding:4rpx 10rpx;border-radius:999rpx;background:#f1f2f4;color:#8a9099;font-size:21rpx}.task-item--done{opacity:.62}.task-item--done .task-item__title{text-decoration:line-through;color:#8a9099}.task-item--closed{opacity:.78}.task-item__actions{display:flex;flex:0 0 auto;align-items:center;margin-left:16rpx}.task-item__check{display:flex;flex:0 0 58rpx;align-items:center;justify-content:center;width:58rpx;min-width:58rpx;max-width:58rpx;height:58rpx;min-height:58rpx;max-height:58rpx;padding:0;box-sizing:border-box;border:3rpx solid #d9dde2;border-radius:50%;background:#fff}.task-item__check--done{border-color:#ff6b35;background:#ff6b35}.task-item__check--disabled{border-color:#d9dde2;background:#f1f2f4}.task-item__check-mark{width:18rpx;height:10rpx;border-left:4rpx solid transparent;border-bottom:4rpx solid transparent;transform:rotate(-45deg)}.task-item__check--done .task-item__check-mark{border-color:#fff}.task-item__loading{width:24rpx;height:24rpx;border:3rpx solid #e7e9ec;border-top-color:#ff6b35;border-radius:50%;animation:task-spin .6s linear infinite}@keyframes task-spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}.task-item__more{display:flex;flex:0 0 54rpx;align-items:center;justify-content:center;width:54rpx;min-width:54rpx;max-width:54rpx;height:58rpx;margin-left:8rpx;padding:0;box-sizing:border-box;background:transparent}.task-item__dot{flex:0 0 6rpx;width:6rpx;min-width:6rpx;max-width:6rpx;height:6rpx;margin:0 3rpx;border-radius:50%;background:#8a9099}