.task{display:flex;align-items:flex-start;margin:0 32rpx 20rpx;padding:27rpx;border-radius:30rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(31,35,41,.05)}.main{flex:1;min-width:0}.title-row{display:flex;align-items:center}.title{margin-left:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1F2329;font-size:28rpx;font-weight:500}.note{display:block;margin-top:12rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#8A9099;font-size:22rpx}.time-row{display:flex;align-items:center;flex-wrap:wrap;margin-top:12rpx}.time,.completed,.closed{margin-right:14rpx;color:#8A9099;font-size:21rpx}.time--overdue{color:#F04A4A}.completed{color:#22B573}.closed{padding:4rpx 10rpx;border-radius:999rpx;background:#F1F2F4;color:#8A9099}.task--done{opacity:.62}.task--done .title{text-decoration:line-through;color:#8A9099}.task--closed{opacity:.78}.actions{display:flex;align-items:center;margin-left:16rpx}.check{display:flex;align-items:center;justify-content:center;width:58rpx;height:58rpx;margin:0;padding:0;border:3rpx solid #D9DDE2;border-radius:50%;background:#fff}.check--done{border-color:#FF6B35;background:#FF6B35}.check--disabled{border-color:#D9DDE2;background:#F1F2F4}.check-mark{width:18rpx;height:10rpx;border-left:4rpx solid transparent;border-bottom:4rpx solid transparent;transform:rotate(-45deg)}.check--done .check-mark{border-color:#fff}.more{display:flex;align-items:center;justify-content:center;width:54rpx;height:58rpx;margin:0 0 0 8rpx;padding:0;background:transparent}.dot{width:6rpx;height:6rpx;margin:0 3rpx;border-radius:50%;background:#8A9099}
