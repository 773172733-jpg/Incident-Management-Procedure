<view class="task-item {{taskData.isCompleted?'task-item--done':''}} {{taskData.status==='closed_by_parent'?'task-item--closed':''}}"><view class="task-item__main" bindtap="edit"><view class="task-item__title-row"><priority-tag priority="{{taskData.priority}}" label="{{taskData.priorityText}}"></priority-tag><text class="task-item__title">{{taskData.title}}</text></view><text wx:if="{{taskData.note}}" class="task-item__note">{{taskData.note}}</text><view class="task-item__time-row"><text class="task-item__time {{taskData.overdue?'task-item__time--overdue':''}}">{{taskData.timeText||'未设置时间'}}</text><text wx:if="{{taskData.completedText}}" class="task-item__completed">{{taskData.completedText}}</text><text wx:if="{{taskData.status==='closed_by_parent'}}" class="task-item__closed">随事件结束</text></view></view><view class="task-item__actions"><view class="task-item__check {{taskData.isCompleted?'task-item__check--done':''}} {{taskData.status==='closed_by_parent'?'task-item__check--disabled':''}} {{operating?'task-item__check--loading':''}}" catchtap="toggle"><view wx:if="{{!operating}}" class="task-item__check-mark"></view><view wx:else class="task-item__loading"></view></view><view class="task-item__more" catchtap="more"><view class="task-item__dot"></view><view class="task-item__dot"></view><view class="task-item__dot"></view></view></view></view>