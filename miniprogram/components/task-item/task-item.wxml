<view class="task {{taskData.isCompleted?'task--done':''}} {{taskData.status==='closed_by_parent'?'task--closed':''}}"><view class="main" bindtap="edit"><view class="title-row"><priority-tag priority="{{taskData.priority}}" label="{{taskData.priorityText}}"></priority-tag><text class="title">{{taskData.title}}</text></view><text wx:if="{{taskData.note}}" class="note">{{taskData.note}}</text><view class="time-row"><text class="time {{taskData.overdue?'time--overdue':''}}">{{taskData.timeText||'未设置时间'}}</text><text wx:if="{{taskData.completedText}}" class="completed">{{taskData.completedText}}</text><text wx:if="{{taskData.status==='closed_by_parent'}}" class="closed">随事件结束</text></view></view><view class="actions"><button class="check {{taskData.isCompleted?'check--done':''}} {{taskData.status==='closed_by_parent'?'check--disabled':''}}" loading="{{operating}}" disabled="{{taskData.status==='closed_by_parent'}}" catchtap="toggle"><view class="check-mark"></view></button><button class="more" catchtap="more"><view class="dot"></view><view class="dot"></view><view class="dot"></view></button></view></view>
