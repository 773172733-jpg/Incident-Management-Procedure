<view class="task {{item.isCompleted?'task--done':''}} {{item.status==='closed_by_parent'?'task--closed':''}}"><text style="color:red;font-size:30rpx;font-weight:bold;display:block;padding:10rpx;">TEST: {{item.title}}</text><view class="task-item__main" bindtap="edit"><view class="task-item__title-row"><priority-tag priority="{{item.priority}}" label="{{item.priorityText}}"></priority-tag><text class="task-item__title">{{item.title}}</text></view><text wx:if="{{item.note}}" class="task-item__note">{{item.note}}</text><view class="task-item__time-row"><text class="task-item__time {{item.overdue?'time--overdue':''}}">{{item.timeText||'未设置时间'}}</text><text wx:if="{{item.completedText}}" class="task-item__completed">{{item.completedText}}</text><text wx:if="{{item.status==='closed_by_parent'}}" class="task-item__closed">随事件结束</text></view></view><view class="actions"><button class="task-item__check {{item.isCompleted?'check--done':''}} {{item.status==='closed_by_parent'?'check--disabled':''}}" loading="{{operating}}" disabled="{{item.status==='closed_by_parent'}}" catchtap="toggle"><view class="task-item__check-mark"></view></button><button class="task-item__more" catchtap="more"><view class="task-item__dot"></view><view class="task-item__dot"></view><view class="task-item__dot"></view></button></view></view>
