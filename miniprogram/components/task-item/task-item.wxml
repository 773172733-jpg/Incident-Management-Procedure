<view class="task {{item.isCompleted?'task--done':''}} {{item.status==='closed_by_parent'?'task--closed':''}}"><view class="main" bindtap="edit"><view class="title-row"><priority-tag priority="{{item.priority}}" label="{{item.priorityText}}"></priority-tag><text class="title">{{item.title}}</text></view><text wx:if="{{item.note}}" class="note">{{item.note}}</text><view class="time-row"><text class="time {{item.overdue?'time--overdue':''}}">{{item.timeText||'未设置时间'}}</text><text wx:if="{{item.completedText}}" class="completed">{{item.completedText}}</text><text wx:if="{{item.status==='closed_by_parent'}}" class="closed">随事件结束</text></view></view><view class="actions"><button class="check {{item.isCompleted?'check--done':''}} {{item.status==='closed_by_parent'?'check--disabled':''}}" loading="{{operating}}" disabled="{{item.status==='closed_by_parent'}}" catchtap="toggle"><view class="check-mark"></view></button><button class="more" catchtap="more"><view class="dot"></view><view class="dot"></view><view class="dot"></view></button></view></view>
