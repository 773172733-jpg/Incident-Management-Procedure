.chip{display:inline-flex;align-items:center;height:58rpx;padding:0 23rpx;border-radius:999rpx;background:#fff;color:#8A9099;font-size:23rpx;white-space:nowrap;box-sizing:border-box}.count{display:inline-flex;align-items:center;justify-content:center;min-width:31rpx;height:31rpx;margin-left:9rpx;padding:0 6rpx;border-radius:999rpx;background:#F1F2F4;font-size:18rpx}.chip--selected{background:#FFF1EA;color:#FF6B35;font-weight:600}.chip--selected .count{background:#fff;color:#FF6B35}.chip--core.chip--selected{background:#FFF0F0;color:#F04A4A}.chip--important.chip--selected{background:#FFF8DF;color:#A87300}.chip--optional.chip--selected{background:#F1F2F4;color:#59606A}
