.card{margin:0 32rpx 22rpx;padding:27rpx;border-radius:30rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(31,35,41,.05)}.head{display:flex;align-items:center}.icon{display:flex;align-items:center;justify-content:center;width:76rpx;height:76rpx;border-radius:22rpx;background:#FFF1EA;font-size:29rpx;font-weight:700;flex-shrink:0}.icon__image{width:66rpx;height:66rpx}.copy{flex:1;min-width:0;margin-left:19rpx}.title,.meta,.extra{display:block}.title{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1F2329;font-size:28rpx;font-weight:600}.meta{margin-top:7rpx;color:#8A9099;font-size:21rpx}.state{padding:5rpx 12rpx;border-radius:999rpx;background:#F1F2F4;color:#8A9099;font-size:19rpx}.progress{display:flex;align-items:center;margin-top:21rpx;color:#8A9099;font-size:20rpx}.track{flex:1;height:10rpx;margin-right:14rpx;border-radius:999rpx;background:#EEF0F3;overflow:hidden}.fill{height:100%;border-radius:999rpx;background:#FF6B35}.extra{margin-top:13rpx;color:#8A9099;font-size:21rpx}.actions{display:flex;justify-content:flex-end;margin-top:20rpx;padding-top:18rpx;border-top:1rpx solid #EEF0F3}.actions button{height:56rpx;margin:0 0 0 12rpx;padding:0 22rpx;border-radius:17rpx;font-size:22rpx;line-height:56rpx}.primary{background:#FFF1EA;color:#FF6B35}.secondary{background:#FFF0F0;color:#F04A4A}
