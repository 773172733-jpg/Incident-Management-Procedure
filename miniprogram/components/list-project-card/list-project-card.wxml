<view class="card"><view class="head"><view class="icon" style="color:{{item.themeColor||'#FF6B35'}}">{{item.iconText||'事'}}</view><view class="copy"><text class="title">{{item.title}}</text><text class="meta">{{item.timeText||item.deletedText||'未设置时间'}}</text></view><text wx:if="{{item.stateText}}" class="state">{{item.stateText}}</text></view><view wx:if="{{showProgress}}" class="progress"><view class="track"><view class="fill" style="width:{{item.progressValue}}%"></view></view><text>{{item.progressValue}}%</text></view><text wx:if="{{item.extraText}}" class="extra">{{item.extraText}}</text><view class="actions"><button wx:if="{{secondaryText}}" class="secondary" bindtap="secondary">{{secondaryText}}</button><button class="primary" bindtap="primary">{{primaryText}}</button></view></view>
