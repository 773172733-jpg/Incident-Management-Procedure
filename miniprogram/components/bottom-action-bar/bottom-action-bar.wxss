.bar{position:fixed;z-index:90;left:0;right:0;bottom:0;padding:20rpx 32rpx 0;background:rgba(255,255,255,.96);box-shadow:0 -8rpx 24rpx rgba(31,35,41,.05)}.bar-button{height:92rpx;line-height:92rpx;border-radius:28rpx;background:#FF6B35;color:#fff;font-size:30rpx;font-weight:600}.bar-button[disabled]{opacity:.55}.safe{height:env(safe-area-inset-bottom)}
